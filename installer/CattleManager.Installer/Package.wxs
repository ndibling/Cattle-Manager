<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Icon Id="AppIcon" SourceFile="..\..\src\CattleManager.App\Assets\app.ico" />

  <Package Name="Herd Master"
           Manufacturer="Herd Master"
           Version="$(var.ProductVersion)"
           UpgradeCode="6F8E9A2B-3C4D-5E6F-7A8B-9C0D1E2F3A4B"
           Language="1033">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Herd Master is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Sets the icon shown in Add/Remove Programs -->
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />

    <!-- Install into Program Files\Herd Master -->
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="Herd Master" />
    </StandardDirectory>

    <!-- Start Menu shortcut -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Component Id="StartMenuShortcut" Guid="C3D4E5F6-A7B8-9012-CDEF-123456789013">
        <Shortcut Id="StartMenu"
                  Name="Herd Master"
                  Target="[INSTALLFOLDER]CattleManager.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="AppIcon" />
        <RemoveFolder Id="RemoveMenuFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\CattleManager"
                       Name="installed"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <Feature Id="ProductFeature" Title="Herd Master" Level="1">
      <!-- PublishFiles is generated at build time from the publish directory -->
      <ComponentGroupRef Id="PublishFiles" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

    <ui:WixUI Id="WixUI_Minimal" InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />
  </Package>
</Wix>
