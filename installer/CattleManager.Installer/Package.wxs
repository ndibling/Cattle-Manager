<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="Cattle Manager"
           Manufacturer="Cattle Manager"
           Version="$(var.ProductVersion)"
           UpgradeCode="6F8E9A2B-3C4D-5E6F-7A8B-9C0D1E2F3A4B"
           Language="1033">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Cattle Manager is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Install into Program Files\Cattle Manager -->
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="Cattle Manager" />
    </StandardDirectory>

    <!-- Start Menu shortcut -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Component Id="StartMenuShortcut" Guid="C3D4E5F6-A7B8-9012-CDEF-123456789013">
        <Shortcut Id="StartMenu"
                  Name="Cattle Manager"
                  Target="[INSTALLFOLDER]CattleManager.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="RemoveMenuFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\CattleManager"
                       Name="installed"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <Feature Id="ProductFeature" Title="Cattle Manager" Level="1">
      <!-- PublishFiles ComponentGroup is generated by HarvestDirectory in the .wixproj -->
      <ComponentGroupRef Id="PublishFiles" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

    <ui:WixUI Id="WixUI_Minimal" InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />
  </Package>
</Wix>
