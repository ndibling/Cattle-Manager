<Project Sdk="WixToolset.Sdk/4.0.5">
  <PropertyGroup>
    <OutputName>CattleManager</OutputName>
    <Platform>x64</Platform>
    <Platforms>x64</Platforms>
    <InstallerPlatform>x64</InstallerPlatform>
    <!-- Bridge MSBuild properties to WiX $(var.xxx) preprocessor variables -->
    <DefineConstants>ProductVersion=$(ProductVersion)</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="WixToolset.UI.wixext" Version="4.0.5" />
  </ItemGroup>

  <!-- Harvest all files from the self-contained publish output -->
  <ItemGroup>
    <HarvestDirectory Include="$(PublishDir)"
                      DirectoryRefId="INSTALLFOLDER"
                      ComponentGroupName="PublishFiles"
                      SuppressRootDirectory="true"
                      SuppressCom="true"
                      SuppressRegistry="true" />
  </ItemGroup>
</Project>
