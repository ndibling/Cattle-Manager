<Application x:Class="CattleManager.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:conv="clr-namespace:CattleManager.App.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemeResources />
                <ui:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>

            <!-- Global converters (available to all pages) -->
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
            <conv:NullToVisibilityConverter x:Key="NullToVisibility"/>
            <conv:StatusToBrushConverter x:Key="StatusToBrush"/>
            <conv:GenderToBrushConverter x:Key="GenderToBrush"/>
            <conv:GenderToBorderBrushConverter x:Key="GenderToBorder"/>
            <conv:GenderToSymbolConverter x:Key="GenderToSymbol"/>
            <conv:OverdueToBrushConverter x:Key="OverdueToBrush"/>
            <conv:CountToWarningColorConverter x:Key="CountToWarningColor"/>
            <conv:PathToImageConverter x:Key="PathToImage"/>
            <conv:IsInHerdToOpacityConverter x:Key="IsInHerdToOpacity"/>

            <!-- Nav button style (used in MainWindow sidebar) -->
            <Style x:Key="NavButtonStyle" TargetType="Button">
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Padding" Value="16,10"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                <Setter Property="Margin" Value="0,2"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Active">
                        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListMediumBrush}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <!-- Status colors -->
            <SolidColorBrush x:Key="StatusHealthyBrush" Color="#2E7D32"/>
            <SolidColorBrush x:Key="StatusPregnantBrush" Color="#1565C0"/>
            <SolidColorBrush x:Key="StatusForSaleBrush" Color="#E65100"/>
            <SolidColorBrush x:Key="StatusInactiveBrush" Color="#757575"/>
            <SolidColorBrush x:Key="StatusOverdueBrush" Color="#F57F17"/>
            <SolidColorBrush x:Key="MaleColorBrush" Color="#1565C0"/>
            <SolidColorBrush x:Key="FemaleColorBrush" Color="#AD1457"/>

            <!-- Card style -->
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="16"/>
                <Setter Property="Margin" Value="8"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.12" Color="Black"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Stat card style -->
            <Style x:Key="StatCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
                <Setter Property="MinWidth" Value="140"/>
                <Setter Property="Padding" Value="20,16"/>
            </Style>

            <!-- Clickable stat card button style -->
            <Style x:Key="StatCardButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
                <Setter Property="MinWidth" Value="140"/>
                <Setter Property="Padding" Value="20,16"/>
                <Setter Property="Margin" Value="8"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}"
                                    MinWidth="{TemplateBinding MinWidth}"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.12" Color="Black"/>
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.82"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Opacity" Value="0.65"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Primary button -->
            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="Background" Value="#2E7D32"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Padding" Value="20,10"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>

            <!-- Section header -->
            <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
                <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
            </Style>

            <!-- Field label -->
            <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                <Setter Property="Margin" Value="0,0,0,2"/>
            </Style>

            <!-- Field value -->
            <Style x:Key="FieldValueStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Margin" Value="0,0,0,12"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <!-- DataGrid row/header dark-mode fix.
                 AlternatingRowBackground must be explicitly set to the same brush as RowBackground —
                 the BasedOn base style may carry a white AlternatingRowBackground that would otherwise
                 show through as white odd rows. DataGridColumnHeader has its own implicit style below. -->
            <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                <Setter Property="RowBackground"             Value="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
                <Setter Property="AlternatingRowBackground"  Value="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
                <Setter Property="Background"                Value="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
                <Setter Property="Foreground"                Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                <Setter Property="RowStyle">
                    <Setter.Value>
                        <!-- Explicit setter so rows don't fall back to Aero2's white DataGridRow style -->
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        </Style>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- DataGridColumnHeader — fix white header background in dark mode -->
            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background"       Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"/>
                <Setter Property="Foreground"       Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                <Setter Property="Padding"          Value="12,6"/>
                <Setter Property="FontWeight"       Value="SemiBold"/>
                <Setter Property="BorderBrush"      Value="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
                <Setter Property="BorderThickness"  Value="0,0,1,1"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
