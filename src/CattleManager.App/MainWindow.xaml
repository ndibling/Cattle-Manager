<Window x:Class="CattleManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Herd Master" Icon="Assets/app.ico" Height="768" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar navigation -->
        <Border Grid.Column="0"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                BorderThickness="0,0,1,0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <DockPanel>
                <!-- Logo / App Name -->
                <StackPanel DockPanel.Dock="Top" Margin="16,24,16,16">
                    <Image Source="/Assets/app-logo.png" Width="56" Height="56" HorizontalAlignment="Center"/>
                    <TextBlock Text="Herd Master" FontSize="18" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,8,0,0"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                </StackPanel>

                <Separator DockPanel.Dock="Top" Margin="12,0"/>

                <!-- Nav buttons -->
                <StackPanel DockPanel.Dock="Top" Margin="8,8">
                    <Button x:Name="BtnDashboard" Content="🏠  Dashboard"
                            Click="BtnDashboard_Click" Style="{StaticResource NavButtonStyle}"
                            Tag="Dashboard"/>
                    <Button x:Name="BtnHerd" Content="🐄  Herds"
                            Click="BtnHerd_Click" Style="{StaticResource NavButtonStyle}"
                            Tag="Herd"/>
                    <Button x:Name="BtnPastureView" Content="🌿  Pasture View"
                            Click="BtnPastureView_Click" Style="{StaticResource NavButtonStyle}"
                            Tag="PastureView"/>
                    <Button x:Name="BtnAddAnimal" Content="➕  Add Animal"
                            Click="BtnAddAnimal_Click" Style="{StaticResource NavButtonStyle}"
                            Tag="Add"/>
                    <Button x:Name="BtnFinancials" Content="💰  Financials"
                            Click="BtnFinancials_Click" Style="{StaticResource NavButtonStyle}"
                            Tag="Financials"/>
                    <Button x:Name="BtnSettings" Content="⚙️  Settings"
                            Click="BtnSettings_Click" Style="{StaticResource NavButtonStyle}"
                            Tag="Settings"/>
                    <Separator Margin="0,8"/>
                    <Button x:Name="BtnHelp" Content="❓  Help &amp; About"
                            Click="BtnHelp_Click" Style="{StaticResource NavButtonStyle}"
                            Tag="Help"/>
                </StackPanel>

                <!-- Version at bottom -->
                <TextBlock DockPanel.Dock="Bottom" Text="v1.0.0"
                           Margin="16,8" FontSize="11"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           HorizontalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Main content frame -->
        <Frame x:Name="MainFrame" Grid.Column="1"
               NavigationUIVisibility="Hidden"
               Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"/>
    </Grid>
</Window>
