<Page x:Class="CattleManager.App.Views.AssetListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      xmlns:conv="clr-namespace:CattleManager.App.Converters"
      Title="Asset Register">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
    </Page.Resources>

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Padding="16,12"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Asset Register" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Border Background="#E8F5E9" CornerRadius="12" Padding="10,4" Margin="12,0,0,0">
                        <TextBlock FontSize="13" VerticalAlignment="Center">
                            <Run Text="{Binding VisibleCount}"/>
                            <Run Text=" assets"/>
                        </TextBlock>
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="+ Add Asset"
                        Command="{Binding AddAssetCommand}"
                        Style="{StaticResource PrimaryButton}"/>
            </Grid>
        </Border>

        <!-- Financial sub-navigation -->
        <Border DockPanel.Dock="Top" Padding="12,6"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Dashboard" Command="{Binding NavigateToDashboardCommand}"
                        Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand"
                        Padding="10,4" VerticalAlignment="Center"/>
                <TextBlock Text="·" FontSize="14" Margin="2,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"/>
                <Button Content="Transactions" Command="{Binding NavigateToTransactionsCommand}"
                        Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand"
                        Padding="10,4" VerticalAlignment="Center"/>
                <TextBlock Text="·" FontSize="14" Margin="2,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Assets" FontSize="13" FontWeight="SemiBold" Padding="10,4"
                           Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="·" FontSize="14" Margin="2,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"/>
                <Button Content="Loans" Command="{Binding NavigateToLoansCommand}"
                        Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand"
                        Padding="10,4" VerticalAlignment="Center"/>
                <TextBlock Text="·" FontSize="14" Margin="2,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"/>
                <Button Content="Reports" Command="{Binding NavigateToReportsCommand}"
                        Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand"
                        Padding="10,4" VerticalAlignment="Center"/>
                <TextBlock Text="·" FontSize="14" Margin="2,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"/>
                <Button Content="Budget" Command="{Binding NavigateToBudgetCommand}"
                        Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand"
                        Padding="10,4" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Filter bar -->
        <Border DockPanel.Dock="Top" Padding="16,10"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ComboBox ItemsSource="{Binding CategoryOptions}"
                          SelectedItem="{Binding FilterCategory}"
                          MinWidth="160" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{Binding StatusOptions}"
                          SelectedItem="{Binding FilterStatus}"
                          MinWidth="100" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <Button Content="Clear Filters" Command="{Binding ClearFiltersCommand}"
                        Padding="12,6" VerticalAlignment="Center"/>
            </WrapPanel>
        </Border>

        <!-- Footer stats -->
        <Border DockPanel.Dock="Bottom" Padding="16,10"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Total Cost Basis:" FontSize="13"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding TotalCostBasis, StringFormat=C}"
                           FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,24,0"/>
                <TextBlock Text="Total Book Value:" FontSize="13"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding TotalBookValue, StringFormat=C}"
                           FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Data grid -->
        <DataGrid ItemsSource="{Binding AssetsView}"
                  SelectedItem="{Binding SelectedAsset}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  SelectionMode="Single"
                  EnableRowVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  RowHeight="40"
                  FontSize="13"
                  MouseDoubleClick="DataGrid_MouseDoubleClick">

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                    <Setter Property="ContextMenu">
                        <Setter.Value>
                            <ContextMenu>
                                <MenuItem Header="Edit"
                                          Command="{Binding DataContext.EditAssetCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                          CommandParameter="{Binding}"/>
                                <Separator/>
                                <MenuItem Header="Delete"
                                          Command="{Binding DataContext.DeleteAssetCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                          CommandParameter="{Binding}"
                                          Foreground="Red"/>
                            </ContextMenu>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <!-- Name -->
                <DataGridTextColumn Header="Asset Name" Binding="{Binding AssetName}"
                                    Width="180" FontWeight="SemiBold"/>
                <!-- Category -->
                <DataGridTextColumn Header="Category" Binding="{Binding CategoryDisplay}" Width="150"/>
                <!-- Purchase Date -->
                <DataGridTextColumn Header="Purchase Date" Binding="{Binding PurchaseDateDisplay}" Width="110"/>
                <!-- Cost Basis -->
                <DataGridTextColumn Header="Cost Basis" Binding="{Binding CostBasisDisplay}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="0,0,8,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <!-- Depreciation Method -->
                <DataGridTextColumn Header="Method" Binding="{Binding DepreciationMethodDisplay}" Width="160"/>
                <!-- Annual Depreciation -->
                <DataGridTextColumn Header="Annual Depr." Binding="{Binding AnnualDepreciationDisplay}" Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="0,0,8,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <!-- Book Value -->
                <DataGridTextColumn Header="Book Value" Binding="{Binding BookValueDisplay}" Width="110">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="0,0,8,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <!-- Linked Animal -->
                <DataGridTextColumn Header="Linked Animal" Binding="{Binding LinkedAnimalName}" Width="120"/>
                <!-- Status badge -->
                <DataGridTemplateColumn Header="Status" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10" Padding="8,3" Margin="4">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#C62828"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="Background" Value="#2E7D32"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Disposed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Text" Value="Active"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <!-- Actions -->
                <DataGridTemplateColumn Header="" Width="40">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="⋮" FontSize="18" Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Padding="4,0"
                                    Click="ActionMenuButton_Click"
                                    Tag="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Page>
