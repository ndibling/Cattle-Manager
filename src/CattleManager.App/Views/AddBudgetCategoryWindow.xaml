<Window x:Class="CattleManager.App.Views.AddBudgetCategoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Add Budget Category"
        Width="500" SizeToContent="Height"
        MinHeight="320" MaxHeight="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,24">

            <!-- Section 1: Type (always visible) -->
            <TextBlock Text="What type of item is this?"
                       FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <Button x:Name="ExpenseBtn" Content="Expense"
                        Width="130" Height="44" FontSize="14"
                        Tag="Expense" Click="TypeBtn_Click"/>
                <Button x:Name="IncomeBtn" Content="Income"
                        Width="130" Height="44" FontSize="14"
                        Margin="12,0,0,0" Tag="Income" Click="TypeBtn_Click"/>
            </StackPanel>

            <!-- Section 2: Category (shown after type chosen) -->
            <StackPanel x:Name="CategorySection" Visibility="Collapsed" Margin="0,0,0,24">
                <TextBlock Text="Category"
                           FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <ComboBox x:Name="CategoryCombo"
                          Width="340" HorizontalAlignment="Left"
                          FontSize="13" Padding="8,6"
                          DisplayMemberPath="Display"
                          SelectionChanged="CategoryCombo_SelectionChanged"/>
            </StackPanel>

            <!-- Section 3: Recurrence (shown after category chosen) -->
            <StackPanel x:Name="RecurrenceSection" Visibility="Collapsed" Margin="0,0,0,24">
                <TextBlock Text="How often does this occur?"
                           FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="OneTimeRadio"
                                 Content="One-Time"
                                 GroupName="Freq" FontSize="14"
                                 Margin="0,0,28,0"
                                 Checked="Recurrence_Changed"/>
                    <RadioButton x:Name="RecurringRadio"
                                 Content="Recurring (same each month)"
                                 GroupName="Freq" FontSize="14"
                                 Checked="Recurrence_Changed"/>
                </StackPanel>
            </StackPanel>

            <!-- Section 4a: One-time date + amount -->
            <StackPanel x:Name="OneTimeSection" Visibility="Collapsed" Margin="0,0,0,24">
                <TextBlock Text="When is this purchase planned?"
                           FontSize="13" Margin="0,0,0,12"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                <StackPanel Orientation="Horizontal">
                    <StackPanel Margin="0,0,24,0">
                        <TextBlock Text="Purchase Date" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <DatePicker x:Name="OneTimeDatePicker" FontSize="13" Width="160"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Amount ($)" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBox x:Name="OneTimeAmountBox"
                                 Width="130" Padding="6,5" FontSize="13" Text="0.00"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- Section 4b: Recurring month amounts -->
            <StackPanel x:Name="RecurringSection" Visibility="Collapsed" Margin="0,0,0,24">
                <TextBlock Text="Set the monthly budget amount"
                           FontSize="13" Margin="0,0,0,12"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Text="Monthly Amount: $"
                               FontSize="14" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox x:Name="RecurringAmountBox"
                             Width="110" Padding="6,5" FontSize="14"
                             Text="0.00"
                             TextChanged="RecurringAmount_Changed"/>
                    <Button Content="Apply to All Months"
                            Margin="12,0,0,0" Padding="12,6" FontSize="13"
                            Click="ApplyToAll_Click"/>
                </StackPanel>
                <TextBlock Text="Or override individual months below:"
                           FontSize="12" Margin="0,0,0,8"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                <StackPanel x:Name="RecurringMonthsPanel"/>
            </StackPanel>

            <!-- Save / Cancel -->
            <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
                <Button x:Name="SaveBtn"
                        Content="Add to Budget"
                        Style="{StaticResource PrimaryButton}"
                        IsEnabled="False"
                        Padding="20,10" FontSize="14"
                        Click="Save_Click"/>
                <Button Content="Cancel"
                        Margin="12,0,0,0" Padding="20,10" FontSize="14"
                        Click="Cancel_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>
