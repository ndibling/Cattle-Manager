<Page x:Class="CattleManager.App.Views.LoanListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="Loans">

    <DockPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Padding="16,12"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Loans" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Border Background="#E3F2FD" CornerRadius="12" Padding="10,4" Margin="12,0,0,0">
                        <TextBlock FontSize="13" VerticalAlignment="Center">
                            <Run Text="{Binding VisibleCount}"/><Run Text=" loans"/>
                        </TextBlock>
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="+ Add Loan"
                        Command="{Binding AddLoanCommand}"
                        Background="#1565C0" Foreground="White"
                        Padding="14,8" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Financial sub-navigation -->
        <Border DockPanel.Dock="Top" Padding="12,6"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Dashboard" Command="{Binding NavigateToDashboardCommand}"
                        Background="Transparent" BorderThickness="0" FontSize="13"
                        Cursor="Hand" Padding="10,4" VerticalAlignment="Center"/>
                <TextBlock Text="·" FontSize="14" Margin="2,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"/>
                <Button Content="Transactions" Command="{Binding NavigateToTransactionsCommand}"
                        Background="Transparent" BorderThickness="0" FontSize="13"
                        Cursor="Hand" Padding="10,4" VerticalAlignment="Center"/>
                <TextBlock Text="·" FontSize="14" Margin="2,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"/>
                <Button Content="Assets" Command="{Binding NavigateToAssetsCommand}"
                        Background="Transparent" BorderThickness="0" FontSize="13"
                        Cursor="Hand" Padding="10,4" VerticalAlignment="Center"/>
                <TextBlock Text="·" FontSize="14" Margin="2,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Loans" FontSize="13" FontWeight="SemiBold" Padding="10,4"
                           Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="·" FontSize="14" Margin="2,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"/>
                <Button Content="Reports" Command="{Binding NavigateToReportsCommand}"
                        Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand"
                        Padding="10,4" VerticalAlignment="Center"/>
                <TextBlock Text="·" FontSize="14" Margin="2,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"/>
                <Button Content="Budget" Command="{Binding NavigateToBudgetCommand}"
                        Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand"
                        Padding="10,4" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Filter bar -->
        <Border DockPanel.Dock="Top" Padding="16,10"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ComboBox ItemsSource="{Binding StatusOptions}"
                          SelectedItem="{Binding FilterStatus}"
                          MinWidth="120" VerticalAlignment="Center"/>
            </WrapPanel>
        </Border>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom" Padding="16,10"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Total Outstanding Debt:" FontSize="13"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding TotalOutstanding, StringFormat=C}"
                           FontSize="14" FontWeight="SemiBold" Foreground="#C62828"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <DataGrid ItemsSource="{Binding LoansView}"
                  SelectedItem="{Binding SelectedLoan}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  SelectionMode="Single"
                  EnableRowVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  RowHeight="42" FontSize="13"
                  MouseDoubleClick="DataGrid_MouseDoubleClick">

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                    <Setter Property="ContextMenu">
                        <Setter.Value>
                            <ContextMenu>
                                <MenuItem Header="View Details"
                                          Command="{Binding DataContext.ViewDetailsCommand,
                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                          CommandParameter="{Binding}"/>
                                <MenuItem Header="Edit"
                                          Command="{Binding DataContext.EditLoanCommand,
                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                          CommandParameter="{Binding}"/>
                                <Separator/>
                                <MenuItem Header="Delete" Foreground="Red"
                                          Command="{Binding DataContext.DeleteLoanCommand,
                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                          CommandParameter="{Binding}"/>
                            </ContextMenu>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Lender"   Binding="{Binding LenderName}"    Width="160"/>
                <DataGridTextColumn Header="Type"     Binding="{Binding LoanTypeDisplay}" Width="170"/>
                <DataGridTextColumn Header="Principal" Binding="{Binding OriginalPrincipalDisplay}" Width="115">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Padding" Value="0,0,8,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Balance" Binding="{Binding CurrentBalanceDisplay}" Width="115">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="0,0,8,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Rate"    Binding="{Binding InterestRateDisplay}"  Width="70"/>
                <DataGridTextColumn Header="Payment" Binding="{Binding PaymentAmountDisplay}" Width="100"/>
                <DataGridTextColumn Header="Next Payment" Binding="{Binding NextPaymentDateDisplay}" Width="115"/>

                <!-- Status badge -->
                <DataGridTemplateColumn Header="Status" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10" Padding="8,3" Margin="4">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#C62828"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="Background" Value="#2E7D32"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Paid Off"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Text" Value="Active"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Actions -->
                <DataGridTemplateColumn Header="" Width="40">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="⋮" FontSize="18" Background="Transparent"
                                    BorderThickness="0" Cursor="Hand" Padding="4,0"
                                    Click="ActionMenu_Click" Tag="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Page>
