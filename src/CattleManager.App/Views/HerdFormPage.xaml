<Page x:Class="CattleManager.App.Views.HerdFormPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      xmlns:conv="clr-namespace:CattleManager.App.Converters"
      Title="Herd Form">

    <Page.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibility"/>
    </Page.Resources>

    <DockPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Padding="16,10"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding FormTitle}" FontSize="22" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="{Binding ValidationError}" Foreground="Red"
                               VerticalAlignment="Center" Margin="0,0,16,0"
                               Visibility="{Binding ValidationError, Converter={StaticResource NullToVisibility}}"/>
                    <Button Content="Save" Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                    <Button Content="Cancel" Command="{Binding CancelCommand}" Padding="16,8"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,16" MaxWidth="600">

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Herd Information" Style="{StaticResource SectionHeaderStyle}"/>

                        <TextBlock Text="Herd Name *" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding HerdName, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="14" Padding="8,6" Margin="0,0,0,12"
                                 ui:ControlHelper.PlaceholderText="e.g. Rolling Hills Angus Herd"/>

                        <TextBlock Text="Herd Type *" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox ItemsSource="{Binding HerdTypeOptions}"
                                  Text="{Binding HerdType, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True"
                                  FontSize="14" Margin="0,0,0,12"/>

                        <CheckBox Content="Active"
                                  IsChecked="{Binding IsActive}"
                                  FontSize="14" Margin="0,4,0,0"/>
                        <TextBlock Text="Inactive herds are hidden from the dashboard herd selector."
                                   FontSize="12" Margin="22,4,0,0"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Page>
