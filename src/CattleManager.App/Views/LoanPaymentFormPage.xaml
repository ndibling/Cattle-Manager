<Page x:Class="CattleManager.App.Views.LoanPaymentFormPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      xmlns:conv="clr-namespace:CattleManager.App.Converters"
      Title="Record Loan Payment">

    <Page.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibility"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:PathToImageConverter      x:Key="PathToImage"/>
    </Page.Resources>

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Padding="16,10"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding FormTitle}"
                           FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="{Binding ValidationError}" Foreground="Red"
                               VerticalAlignment="Center" Margin="0,0,16,0"
                               Visibility="{Binding ValidationError, Converter={StaticResource NullToVisibility}}"/>
                    <Button Content="Save" Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                    <Button Content="Cancel" Command="{Binding CancelCommand}" Padding="16,8"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,16,24,24">

                <!-- Loan Selection -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Loan" Style="{StaticResource SectionHeaderStyle}"/>
                        <StackPanel>
                            <TextBlock Text="Loan *" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding ActiveLoans}"
                                      SelectedItem="{Binding SelectedLoan}"
                                      FontSize="14" MaxWidth="400" HorizontalAlignment="Left"
                                      ui:ControlHelper.PlaceholderText="Select the loan being paid">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding LenderName}"/>
                                            <TextBlock Text=" — "/>
                                            <TextBlock Text="{Binding LoanTypeDisplay}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Text="{Binding CurrentLoanBalanceDisplay}"
                                       FontSize="15" FontWeight="SemiBold" Margin="0,8,0,0"
                                       Foreground="#E65100"
                                       Visibility="{Binding CurrentLoanBalance, Converter={StaticResource NullToVisibility}}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Payment Details -->
                <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Text="Payment Details" Style="{StaticResource SectionHeaderStyle}"/>
                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="Payment Date *" Style="{StaticResource FieldLabelStyle}"/>
                            <DatePicker SelectedDate="{Binding Date}" FontSize="14" MaxWidth="200" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="160"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto" MinWidth="160"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto" MinWidth="160"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Principal Paid ($) *" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding PrincipalText, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="14" Padding="8,6" Width="150"
                                         ui:ControlHelper.PlaceholderText="0.00"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Interest Paid ($) *" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding InterestText, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="14" Padding="8,6" Width="150"
                                         ui:ControlHelper.PlaceholderText="0.00"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Total Payment" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBlock Text="{Binding TotalPaymentDisplay}"
                                           FontSize="18" FontWeight="SemiBold" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Margin="0,12,0,0" FontSize="12"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   TextWrapping="Wrap">
                            Principal reduces the loan balance. Both principal and interest are recorded as farm expenses.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Payment Info -->
                <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Text="Payment Info" Style="{StaticResource SectionHeaderStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Payee (Lender)" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding PayeePayer, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="14" Padding="8,6"
                                         ui:ControlHelper.PlaceholderText="Lender name"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Payment Method" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding PaymentMethod, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="14" Padding="8,6"
                                         ui:ControlHelper.PlaceholderText="ACH, check, online…"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Text="Description" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="14" Padding="8,6"
                                     ui:ControlHelper.PlaceholderText="Optional — defaults to 'Loan payment — [lender]'"/>
                        </StackPanel>
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Text="Notes" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="14" Padding="8,6"
                                     AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                                     ui:ControlHelper.PlaceholderText="Optional notes"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Receipt / Attachment -->
                <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Text="Receipt / Attachment" Style="{StaticResource SectionHeaderStyle}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="Browse..." Command="{Binding BrowseAttachmentCommand}"
                                    Padding="12,6" Margin="0,0,8,0"/>
                            <Button Content="Clear" Command="{Binding ClearAttachmentCommand}"
                                    Padding="12,6"
                                    Visibility="{Binding AttachmentPath, Converter={StaticResource NullToVisibility}}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding AttachmentPath}" FontSize="12" TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   Visibility="{Binding AttachmentPath, Converter={StaticResource NullToVisibility}}"/>
                        <Image Source="{Binding AttachmentPath, Converter={StaticResource PathToImage}}"
                               MaxHeight="160" MaxWidth="240" HorizontalAlignment="Left" Margin="0,8,0,0"
                               Stretch="Uniform"
                               Visibility="{Binding IsImageAttachment, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Page>
