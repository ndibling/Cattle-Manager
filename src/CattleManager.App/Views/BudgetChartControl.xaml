<UserControl x:Class="CattleManager.App.Views.BudgetChartControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Margin="16,8,16,0" CornerRadius="6"
            Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
            BorderThickness="1"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
        <StackPanel>

            <!-- Chart title -->
            <TextBlock Text="Budget vs. Actual by Month"
                       FontSize="13" FontWeight="SemiBold"
                       Margin="16,10,16,4"
                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>

            <!-- Canvas — drawing happens in code-behind -->
            <Canvas x:Name="ChartCanvas" Height="200"
                    Margin="0,0,0,0"
                    SizeChanged="ChartCanvas_SizeChanged"/>

            <!-- Legend -->
            <StackPanel Orientation="Horizontal" Margin="16,4,16,10"
                        HorizontalAlignment="Center">
                <Rectangle Width="13" Height="13" Fill="#90CAF9" RadiusX="2" RadiusY="2"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Budgeted Income" FontSize="11" Margin="4,0,16,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>

                <Rectangle Width="13" Height="13" Fill="#43A047" RadiusX="2" RadiusY="2"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Actual Income" FontSize="11" Margin="4,0,16,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>

                <Rectangle Width="13" Height="13" Fill="#FFCC80" RadiusX="2" RadiusY="2"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Budgeted Expense" FontSize="11" Margin="4,0,16,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>

                <Rectangle Width="13" Height="13" Fill="#EF5350" RadiusX="2" RadiusY="2"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Actual Expense" FontSize="11" Margin="4,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            </StackPanel>

        </StackPanel>
    </Border>
</UserControl>
