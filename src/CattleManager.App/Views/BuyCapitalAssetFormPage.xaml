<Page x:Class="CattleManager.App.Views.BuyCapitalAssetFormPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      xmlns:conv="clr-namespace:CattleManager.App.Converters"
      Title="Buy Capital Asset">

    <Page.Resources>
        <conv:NullToVisibilityConverter      x:Key="NullToVisibility"/>
        <conv:BoolToVisibilityConverter      x:Key="BoolToVisibility"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <conv:PathToImageConverter           x:Key="PathToImage"/>
    </Page.Resources>

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Padding="16,10"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding FormTitle}"
                           FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="{Binding ValidationError}" Foreground="Red"
                               VerticalAlignment="Center" Margin="0,0,16,0"
                               Visibility="{Binding ValidationError, Converter={StaticResource NullToVisibility}}"/>
                    <Button Content="Save" Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                    <Button Content="Cancel" Command="{Binding CancelCommand}" Padding="16,8"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,16,24,24">

                <!-- Transaction Details -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Transaction Details" Style="{StaticResource SectionHeaderStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="160"/>
                                <ColumnDefinition Width="Auto" MinWidth="200"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,24,0">
                                <TextBlock Text="Date *" Style="{StaticResource FieldLabelStyle}"/>
                                <DatePicker SelectedDate="{Binding Date}" FontSize="14"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Purchase Price *" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="14" Padding="8,6" Width="160"
                                         ui:ControlHelper.PlaceholderText="0.00"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Text="Description *" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="14" Padding="8,6"
                                     ui:ControlHelper.PlaceholderText="e.g. New John Deere 5075E tractor"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Asset Details (always visible for BuyCapitalAsset) -->
                <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Text="Asset Details" Style="{StaticResource SectionHeaderStyle}"/>
                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="Asset Name *" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding AssetName, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="14" Padding="8,6" MaxWidth="400" HorizontalAlignment="Left"
                                     ui:ControlHelper.PlaceholderText="Name for the asset register"/>
                        </StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Asset Category *" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding AssetCategoryOptions}"
                                          SelectedItem="{Binding SelectedAssetCategory}"
                                          DisplayMemberPath="Display"
                                          FontSize="14"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Depreciation Method *" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding AssetDepreciationOptions}"
                                          SelectedItem="{Binding SelectedAssetDepreciation}"
                                          DisplayMemberPath="Display"
                                          FontSize="14"/>
                            </StackPanel>
                        </Grid>
                        <Grid Visibility="{Binding ShowAssetDepreciationDetails, Converter={StaticResource BoolToVisibility}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="160"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto" MinWidth="160"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Useful Life (years)" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding AssetUsefulLifeText, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="14" Padding="8,6" Width="120"
                                         ui:ControlHelper.PlaceholderText="7"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Salvage Value ($)" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding AssetSalvageValueText, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="14" Padding="8,6" Width="120"
                                         ui:ControlHelper.PlaceholderText="0.00"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Vendor Details -->
                <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Text="Vendor Details" Style="{StaticResource SectionHeaderStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Vendor / Seller" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding PayeePayer, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="14" Padding="8,6"
                                         ui:ControlHelper.PlaceholderText="Dealer or seller name"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Payment Method" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding PaymentMethod, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="14" Padding="8,6"
                                         ui:ControlHelper.PlaceholderText="Check, financing, cash…"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Text="Notes" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="14" Padding="8,6"
                                     AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                                     ui:ControlHelper.PlaceholderText="Optional notes or memo"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Receipt / Attachment -->
                <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Text="Receipt / Attachment" Style="{StaticResource SectionHeaderStyle}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="Browse..." Command="{Binding BrowseAttachmentCommand}"
                                    Padding="12,6" Margin="0,0,8,0"/>
                            <Button Content="Clear" Command="{Binding ClearAttachmentCommand}"
                                    Padding="12,6"
                                    Visibility="{Binding AttachmentPath, Converter={StaticResource NullToVisibility}}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding AttachmentPath}" FontSize="12" TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   Visibility="{Binding AttachmentPath, Converter={StaticResource NullToVisibility}}"/>
                        <Image Source="{Binding AttachmentPath, Converter={StaticResource PathToImage}}"
                               MaxHeight="160" MaxWidth="240" HorizontalAlignment="Left" Margin="0,8,0,0"
                               Stretch="Uniform"
                               Visibility="{Binding IsImageAttachment, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Page>
