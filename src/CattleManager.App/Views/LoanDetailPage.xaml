<Page x:Class="CattleManager.App.Views.LoanDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="Loan Detail">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="Auto"/>  <!-- Summary card -->
            <RowDefinition Height="*"/>     <!-- Amortization schedule -->
            <RowDefinition Height="Auto"/>  <!-- Recorded payments panel (max 300) -->
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Padding="16,10"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="← Back" Command="{Binding NavigateBackCommand}"
                            Background="Transparent" BorderThickness="0"
                            FontSize="13" Cursor="Hand" Padding="0,4,16,4"/>
                    <TextBlock Text="{Binding LenderName}"
                               FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Border Background="#E3F2FD" CornerRadius="12" Padding="10,4" Margin="12,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentBalanceLabel}"
                                   FontSize="13" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
                <Button Grid.Column="1" Content="Edit Loan" Command="{Binding EditLoanCommand}"
                        Padding="14,8" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Loan summary card -->
        <Border Grid.Row="1" Margin="16,12,16,0" Padding="14,10"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1" CornerRadius="6"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
            <StackPanel>
                <TextBlock Text="{Binding SummaryLine1}" FontSize="13"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumHighBrush}"/>
                <TextBlock Text="{Binding SummaryLine2}" FontSize="12" Margin="0,3,0,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            </StackPanel>
        </Border>

        <!-- Amortization schedule -->
        <DockPanel Grid.Row="2" Margin="16,12,16,0" MinHeight="120">
            <TextBlock DockPanel.Dock="Top" Text="Amortization Schedule"
                       FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <DataGrid ItemsSource="{Binding Schedule}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      SelectionMode="Single"
                      EnableRowVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      RowHeight="34" FontSize="13">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        <Style.Triggers>
                            <!-- Past periods are dimmed -->
                            <DataTrigger Binding="{Binding IsPaid}" Value="True">
                                <Setter Property="Foreground"
                                        Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#"           Binding="{Binding PeriodNumber}"   Width="42"/>
                    <DataGridTextColumn Header="Date"        Binding="{Binding PaymentDateDisplay}" Width="110"/>
                    <DataGridTextColumn Header="Payment"     Binding="{Binding PaymentDisplay}"  Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="0,0,8,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Principal"   Binding="{Binding PrincipalDisplay}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="0,0,8,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Interest"    Binding="{Binding InterestDisplay}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Padding" Value="0,0,8,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Remaining Balance" Binding="{Binding BalanceDisplay}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="0,0,8,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

        <!-- Recorded payments panel -->
        <Border Grid.Row="3" Margin="16,8,16,16" Padding="14,10"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1" CornerRadius="6"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                MaxHeight="300">
            <DockPanel>

                <!-- Panel header -->
                <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Recorded Payments"
                               FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Command="{Binding ToggleRecordPaymentCommand}"
                            Padding="12,5" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Content" Value="+ Record Payment"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRecordingPayment}" Value="True">
                                        <Setter Property="Content" Value="✕ Cancel"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <!-- Inline record-payment form -->
                <Border DockPanel.Dock="Top"
                        Visibility="{Binding IsRecordingPayment, Converter={StaticResource BoolToVisibility}}"
                        Padding="10,8" Margin="0,0,0,8" CornerRadius="4"
                        Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Payment Date" Style="{StaticResource FieldLabelStyle}"/>
                                <DatePicker SelectedDate="{Binding NewPaymentDate}" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <TextBlock Text="Principal ($)" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding NewPrincipalText, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="13" Padding="6,5"
                                         ui:ControlHelper.PlaceholderText="0.00"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                <TextBlock Text="Interest ($)" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding NewInterestText, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="13" Padding="6,5"
                                         ui:ControlHelper.PlaceholderText="0.00"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Margin="0,0,12,0">
                                <TextBlock Text="Total" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBlock Text="{Binding NewTotalDisplay}"
                                           FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="4" Content="Save Payment"
                                    Command="{Binding SavePaymentCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Padding="12,7" VerticalAlignment="Bottom"/>
                        </Grid>
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding NewNotesText, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="13" Padding="6,5"
                                     ui:ControlHelper.PlaceholderText="Notes (optional)"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding PaymentError}" Foreground="#C62828"
                                       FontSize="12" Margin="12,0,0,0" VerticalAlignment="Center"
                                       Visibility="{Binding PaymentError, Converter={StaticResource NullToVisibility}}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Payments DataGrid -->
                <DataGrid ItemsSource="{Binding Payments}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          SelectionMode="Single"
                          RowHeight="34" FontSize="13">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date"
                                            Binding="{Binding PaymentDate, StringFormat=MM/dd/yyyy}"
                                            Width="110"/>
                        <DataGridTextColumn Header="Principal"
                                            Binding="{Binding PrincipalPortion, StringFormat=C}"
                                            Width="100"/>
                        <DataGridTextColumn Header="Interest"
                                            Binding="{Binding InterestPortion, StringFormat=C}"
                                            Width="100"/>
                        <DataGridTextColumn Header="Total"
                                            Binding="{Binding TotalPayment, StringFormat=C}"
                                            Width="100"/>
                        <DataGridTextColumn Header="Remaining Balance"
                                            Binding="{Binding RemainingBalance, StringFormat=C}"
                                            Width="140"/>
                        <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*"/>
                        <DataGridTemplateColumn Header="" Width="36">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="✕" FontSize="12"
                                            Background="Transparent" BorderThickness="0"
                                            Cursor="Hand" Padding="4,0"
                                            Foreground="#C62828"
                                            Click="DeletePayment_Click" Tag="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

            </DockPanel>
        </Border>

    </Grid>
</Page>
