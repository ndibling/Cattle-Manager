<Page x:Class="CattleManager.App.Views.FinancialDashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="Financial Overview">

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Padding="16,12"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Financial Overview" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Border Background="#E8F5E9" CornerRadius="12" Padding="10,4" Margin="12,0,0,0"
                            Visibility="{Binding FiscalYearDisplay, Converter={StaticResource NullToVisibility}}">
                        <TextBlock Text="{Binding FiscalYearDisplay}" FontSize="13" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" FontSize="13"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                        Loading…
                    </TextBlock>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="+ Add Expense"
                            Command="{Binding AddExpenseCommand}"
                            Background="#C62828" Foreground="White"
                            Padding="14,8" Margin="0,0,6,0" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="+ Add Income"
                            Command="{Binding AddIncomeCommand}"
                            Background="#2E7D32" Foreground="White"
                            Padding="14,8" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Financial sub-navigation -->
        <Border DockPanel.Dock="Top" Padding="12,6"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Dashboard" FontSize="13" FontWeight="SemiBold" Padding="10,4"
                           Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="·" FontSize="14" Margin="2,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"/>
                <Button Content="Transactions" Command="{Binding NavigateToTransactionsCommand}"
                        Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand"
                        Padding="10,4" VerticalAlignment="Center"/>
                <TextBlock Text="·" FontSize="14" Margin="2,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"/>
                <Button Content="Assets" Command="{Binding NavigateToAssetsCommand}"
                        Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand"
                        Padding="10,4" VerticalAlignment="Center"/>
                <TextBlock Text="·" FontSize="14" Margin="2,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"/>
                <Button Content="Loans" Command="{Binding NavigateToLoansCommand}"
                        Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand"
                        Padding="10,4" VerticalAlignment="Center"/>
                <TextBlock Text="·" FontSize="14" Margin="2,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"/>
                <Button Content="Reports" Command="{Binding NavigateToReportsCommand}"
                        Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand"
                        Padding="10,4" VerticalAlignment="Center"/>
                <TextBlock Text="·" FontSize="14" Margin="2,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"/>
                <Button Content="Budget" Command="{Binding NavigateToBudgetCommand}"
                        Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand"
                        Padding="10,4" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main scrollable content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,16,24,24">

                <!-- KPI tiles -->
                <TextBlock Text="Key Performance Indicators" Style="{StaticResource SectionHeaderStyle}"/>
                <WrapPanel Margin="0,0,0,24" Orientation="Horizontal">

                    <Button Style="{StaticResource StatCardButtonStyle}"
                            Command="{Binding NavigateToReportsCommand}">
                        <Button.ToolTip>
                            <ToolTip>
                                <StackPanel MaxWidth="260">
                                    <TextBlock Text="Net Farm Income" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="12"
                                               Text="Your farm's bottom line for the current fiscal year — the profit (or loss) after all expenses are paid."/>
                                    <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,6,0,0"
                                               Foreground="#888888"
                                               Text="Formula: Total Revenue − Total Expenses"/>
                                </StackPanel>
                            </ToolTip>
                        </Button.ToolTip>
                        <StackPanel>
                            <TextBlock Text="{Binding NetFarmIncomeDisplay}" FontSize="28" FontWeight="Bold"
                                       Foreground="#2E7D32" HorizontalAlignment="Center"/>
                            <TextBlock Text="Net Farm Income" FontSize="12" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource StatCardButtonStyle}"
                            Command="{Binding NavigateToTransactionsCommand}">
                        <Button.ToolTip>
                            <ToolTip>
                                <StackPanel MaxWidth="260">
                                    <TextBlock Text="Total Revenue" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="12"
                                               Text="The sum of all income transactions recorded for the current fiscal year, including livestock sales, breeding services, and any other farm income."/>
                                    <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,6,0,0"
                                               Foreground="#888888"
                                               Text="Formula: Sum of all Income transactions this fiscal year"/>
                                </StackPanel>
                            </ToolTip>
                        </Button.ToolTip>
                        <StackPanel>
                            <TextBlock Text="{Binding TotalRevenueDisplay}" FontSize="28" FontWeight="Bold"
                                       Foreground="#1565C0" HorizontalAlignment="Center"/>
                            <TextBlock Text="Total Revenue" FontSize="12" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource StatCardButtonStyle}"
                            Command="{Binding NavigateToTransactionsCommand}">
                        <Button.ToolTip>
                            <ToolTip>
                                <StackPanel MaxWidth="260">
                                    <TextBlock Text="Total Expenses" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="12"
                                               Text="The sum of all expense transactions recorded for the current fiscal year, including feed, veterinary, labor, equipment, and other operating costs."/>
                                    <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,6,0,0"
                                               Foreground="#888888"
                                               Text="Formula: Sum of all Expense transactions this fiscal year"/>
                                </StackPanel>
                            </ToolTip>
                        </Button.ToolTip>
                        <StackPanel>
                            <TextBlock Text="{Binding TotalExpensesDisplay}" FontSize="28" FontWeight="Bold"
                                       Foreground="#C62828" HorizontalAlignment="Center"/>
                            <TextBlock Text="Total Expenses" FontSize="12" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource StatCardButtonStyle}"
                            Command="{Binding NavigateToLoansCommand}">
                        <Button.ToolTip>
                            <ToolTip>
                                <StackPanel MaxWidth="260">
                                    <TextBlock Text="Debt-to-Asset Ratio" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="12"
                                               Text="Measures how much of your farm's assets are financed by debt. A lower ratio indicates stronger financial health. Below 0.5 is generally considered low risk; above 0.7 signals high leverage."/>
                                    <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,6,0,0"
                                               Foreground="#888888"
                                               Text="Formula: Total Liabilities ÷ Total Assets"/>
                                </StackPanel>
                            </ToolTip>
                        </Button.ToolTip>
                        <StackPanel>
                            <TextBlock Text="{Binding DebtToAssetDisplay}" FontSize="28" FontWeight="Bold"
                                       Foreground="#E65100" HorizontalAlignment="Center"/>
                            <TextBlock Text="Debt-to-Asset Ratio" FontSize="12" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource StatCardButtonStyle}"
                            Command="{Binding NavigateToAssetsCommand}">
                        <Button.ToolTip>
                            <ToolTip>
                                <StackPanel MaxWidth="260">
                                    <TextBlock Text="Avg Cost / Head" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="12"
                                               Text="The average total farm expense allocated to each active animal this fiscal year. Useful for benchmarking efficiency and setting sale prices."/>
                                    <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,6,0,0"
                                               Foreground="#888888"
                                               Text="Formula: Total Expenses ÷ Number of Active Animals"/>
                                </StackPanel>
                            </ToolTip>
                        </Button.ToolTip>
                        <StackPanel>
                            <TextBlock Text="{Binding AvgCostPerHeadDisplay}" FontSize="28" FontWeight="Bold"
                                       Foreground="#6A1B9A" HorizontalAlignment="Center"/>
                            <TextBlock Text="Avg Cost / Head" FontSize="12" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource StatCardButtonStyle}">
                        <Button.ToolTip>
                            <ToolTip>
                                <StackPanel MaxWidth="260">
                                    <TextBlock Text="Break-Even Price" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="12"
                                               Text="The minimum price per animal you must receive on sales to cover all farm expenses for the year. If your actual sale prices fall below this, the operation is running at a loss."/>
                                    <TextBlock TextWrapping="Wrap" FontSize="12" Margin="0,6,0,0"
                                               Foreground="#888888"
                                               Text="Formula: Total Expenses ÷ Number of Animals Sold This Year"/>
                                </StackPanel>
                            </ToolTip>
                        </Button.ToolTip>
                        <StackPanel>
                            <TextBlock Text="{Binding BreakEvenPriceDisplay}" FontSize="28" FontWeight="Bold"
                                       Foreground="#F57F17" HorizontalAlignment="Center"/>
                            <TextBlock Text="Break-Even Price" FontSize="12" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>

                </WrapPanel>

                <!-- Monthly bar chart -->
                <TextBlock Text="Revenue vs. Expenses — This Year" Style="{StaticResource SectionHeaderStyle}"/>
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                    <StackPanel>
                        <!-- Legend -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Border Width="14" Height="14" Background="#2E7D32" CornerRadius="2"
                                    VerticalAlignment="Center"/>
                            <TextBlock Text="Revenue" FontSize="12" Margin="6,0,16,0" VerticalAlignment="Center"/>
                            <Border Width="14" Height="14" Background="#C62828" CornerRadius="2"
                                    VerticalAlignment="Center"/>
                            <TextBlock Text="Expenses" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="No transaction data for this year."
                                   FontSize="13" Margin="0,8"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   Visibility="{Binding HasMonthlyBars, Converter={StaticResource InverseBoolToVisibility}}"/>

                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                      Visibility="{Binding HasMonthlyBars, Converter={StaticResource BoolToVisibility}}">
                            <ItemsControl ItemsSource="{Binding MonthlyBars}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Width="52" Margin="2,0" HorizontalAlignment="Center">
                                            <Grid Height="110">
                                                <StackPanel VerticalAlignment="Bottom" Orientation="Horizontal"
                                                            HorizontalAlignment="Center">
                                                    <Border Width="16" Height="{Binding RevenueHeight}"
                                                            Background="#2E7D32" VerticalAlignment="Bottom"
                                                            ToolTip="{Binding RevenueDisplay}"/>
                                                    <Border Width="4"/>
                                                    <Border Width="16" Height="{Binding ExpenseHeight}"
                                                            Background="#C62828" VerticalAlignment="Bottom"
                                                            ToolTip="{Binding ExpenseDisplay}"/>
                                                </StackPanel>
                                            </Grid>
                                            <TextBlock Text="{Binding MonthLabel}" FontSize="9"
                                                       HorizontalAlignment="Center" Margin="0,3"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- Quick Actions -->
                <TextBlock Text="Quick Actions" Style="{StaticResource SectionHeaderStyle}"/>
                <WrapPanel Orientation="Horizontal">
                    <Button Content="View Reports"
                            Command="{Binding NavigateToReportsCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,12,12"/>
                    <Button Content="Manage Assets"
                            Command="{Binding NavigateToAssetsCommand}"
                            Padding="20,10" FontSize="14" Margin="0,0,12,12"/>
                    <Button Content="View Loans"
                            Command="{Binding NavigateToLoansCommand}"
                            Padding="20,10" FontSize="14" Margin="0,0,12,12"/>
                    <Button Content="Manage Budget"
                            Command="{Binding NavigateToBudgetCommand}"
                            Padding="20,10" FontSize="14" Margin="0,0,12,12"/>
                    <Button Content="All Transactions"
                            Command="{Binding NavigateToTransactionsCommand}"
                            Padding="20,10" FontSize="14" Margin="0,0,12,12"/>
                </WrapPanel>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Page>
