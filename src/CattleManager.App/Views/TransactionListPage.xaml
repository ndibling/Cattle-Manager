<Page x:Class="CattleManager.App.Views.TransactionListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      xmlns:conv="clr-namespace:CattleManager.App.Converters"
      Title="Transactions">

    <Page.Resources>
        <conv:TransactionTypeToBrushConverter x:Key="TypeToBrush"/>
    </Page.Resources>

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Padding="16,12"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Transactions" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Border Background="#E8F5E9" CornerRadius="12" Padding="10,4" Margin="12,0,0,0">
                        <TextBlock FontSize="13" VerticalAlignment="Center">
                            <Run Text="{Binding VisibleCount}"/>
                            <Run Text=" entries"/>
                        </TextBlock>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="+ Add Income"
                            Command="{Binding AddTransactionCommand}" CommandParameter="Income"
                            Background="#2E7D32" Foreground="White"
                            Padding="14,8" Margin="0,0,6,0" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="+ Add Expense"
                            Command="{Binding AddTransactionCommand}" CommandParameter="Expense"
                            Background="#C62828" Foreground="White"
                            Padding="14,8" Margin="0,0,6,0" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="+ Add Capital"
                            Command="{Binding AddTransactionCommand}" CommandParameter="Capital"
                            Background="#1565C0" Foreground="White"
                            Padding="14,8" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Financial sub-navigation -->
        <Border DockPanel.Dock="Top" Padding="12,6"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Transactions" FontSize="13" FontWeight="SemiBold" Padding="10,4"
                           Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="·" FontSize="14" Margin="2,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"/>
                <Button Content="Assets" Command="{Binding NavigateToAssetsCommand}"
                        Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand"
                        Padding="10,4" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Filter bar -->
        <Border DockPanel.Dock="Top" Padding="16,10"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                    <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="13"/>
                    <DatePicker SelectedDate="{Binding FilterDateFrom}" VerticalAlignment="Center" MinWidth="130"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                    <TextBlock Text="To:" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="13"/>
                    <DatePicker SelectedDate="{Binding FilterDateTo}" VerticalAlignment="Center" MinWidth="130"/>
                </StackPanel>
                <ComboBox ItemsSource="{Binding TypeOptions}"
                          SelectedItem="{Binding FilterType}"
                          MinWidth="110" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <Button Content="Clear Filters" Command="{Binding ClearFiltersCommand}"
                        Padding="12,6" VerticalAlignment="Center"/>
            </WrapPanel>
        </Border>

        <!-- Footer stats -->
        <Border DockPanel.Dock="Bottom" Padding="16,10"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Income:" FontSize="13"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding TotalIncome, StringFormat=C}"
                           FontSize="14" FontWeight="SemiBold" Foreground="#2E7D32"
                           VerticalAlignment="Center" Margin="0,0,24,0"/>
                <TextBlock Text="Expenses:" FontSize="13"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding TotalExpenses, StringFormat=C}"
                           FontSize="14" FontWeight="SemiBold" Foreground="#C62828"
                           VerticalAlignment="Center" Margin="0,0,24,0"/>
                <TextBlock Text="Net:" FontSize="13"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding NetAmount, StringFormat=C}"
                           FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Data grid -->
        <DataGrid ItemsSource="{Binding TransactionsView}"
                  SelectedItem="{Binding SelectedTransaction}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  SelectionMode="Single"
                  EnableRowVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  RowHeight="40"
                  FontSize="13"
                  MouseDoubleClick="DataGrid_MouseDoubleClick">

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="ContextMenu">
                        <Setter.Value>
                            <ContextMenu>
                                <MenuItem Header="Edit"
                                          Command="{Binding DataContext.EditTransactionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                          CommandParameter="{Binding}"/>
                                <Separator/>
                                <MenuItem Header="Delete"
                                          Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                          CommandParameter="{Binding}"
                                          Foreground="Red"/>
                            </ContextMenu>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <!-- Date -->
                <DataGridTextColumn Header="Date"
                                    Binding="{Binding Date, StringFormat=MM/dd/yyyy}"
                                    Width="95"/>
                <!-- Type badge -->
                <DataGridTemplateColumn Header="Type" Width="85">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="10" Padding="8,3" Margin="4"
                                    Background="{Binding TransactionType, Converter={StaticResource TypeToBrush}}">
                                <TextBlock Text="{Binding TypeDisplay}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <!-- Category -->
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="160"/>
                <!-- Description -->
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                <!-- Payee/Payer -->
                <DataGridTextColumn Header="Payee / Payer" Binding="{Binding PayeePayer}" Width="140"/>
                <!-- Amount -->
                <DataGridTextColumn Header="Amount" Binding="{Binding AmountDisplay}"
                                    Width="100" ElementStyle="{x:Null}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="0,0,8,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <!-- Actions -->
                <DataGridTemplateColumn Header="" Width="40">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="⋮" FontSize="18" Background="Transparent" BorderThickness="0"
                                    Cursor="Hand" Padding="4,0"
                                    Click="ActionMenuButton_Click"
                                    Tag="{Binding}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Page>
