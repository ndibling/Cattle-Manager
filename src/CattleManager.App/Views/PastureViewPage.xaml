<Page x:Class="CattleManager.App.Views.PastureViewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      xmlns:vm="clr-namespace:CattleManager.App.ViewModels"
      Background="{DynamicResource SystemControlBackgroundAltMediumBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Border Grid.Row="0" Padding="20,14,20,10"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,0,1"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🌿" FontSize="22" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Pasture View" FontSize="20" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Filter herd:" VerticalAlignment="Center" FontSize="13" Margin="0,0,10,0"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <ComboBox ItemsSource="{Binding HerdFilterOptions}"
                              SelectedItem="{Binding SelectedHerd}"
                              DisplayMemberPath="HerdName"
                              MinWidth="160" FontSize="13"
                              ui:ControlHelper.PlaceholderText="All Herds"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading overlay -->
        <Border Grid.Row="1" Background="{DynamicResource SystemControlBackgroundAltMediumBrush}"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                Panel.ZIndex="10">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:ProgressRing IsActive="True" Width="48" Height="48"/>
                <TextBlock Text="Loading pastures…" FontSize="14" Margin="0,12,0,0"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            </StackPanel>
        </Border>

        <!-- Board -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Padding="16,12">
            <ItemsControl ItemsSource="{Binding HerdGroups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:HerdBoardGroup}">
                        <Border Margin="0,0,0,24" CornerRadius="8"
                                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                BorderThickness="1">
                            <StackPanel>
                                <!-- Herd header -->
                                <Border Padding="16,10" CornerRadius="8,8,0,0"
                                        Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Herd.HerdName}" FontSize="15" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                                        <TextBlock Margin="8,0,0,0" FontSize="13" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}">
                                            <Run Text="("/>
                                            <Run Text="{Binding TotalAnimalCount, Mode=OneWay}"/>
                                            <Run Text=" animals)"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- Pasture lanes row -->
                                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Disabled"
                                              Padding="12,12,12,12">
                                    <StackPanel Orientation="Horizontal">
                                        <ItemsControl ItemsSource="{Binding Lanes}" x:Name="LanesControl">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:PastureLane}">
                                                    <Border Margin="0,0,12,0" Width="200" CornerRadius="6"
                                                            BorderThickness="2"
                                                            x:Name="LaneBorder"
                                                            AllowDrop="True"
                                                            Drop="PastureLane_Drop"
                                                            DragOver="PastureLane_DragOver"
                                                            DragLeave="PastureLane_DragLeave"
                                                            Tag="{Binding}">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background"
                                                                        Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"/>
                                                                <Setter Property="BorderBrush"
                                                                        Value="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsDragOver}" Value="True">
                                                                        <Setter Property="BorderBrush" Value="#2E7D32"/>
                                                                        <Setter Property="Background" Value="#E8F5E9"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsUnassigned}" Value="True">
                                                                        <Setter Property="BorderBrush"
                                                                                Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>

                                                        <StackPanel>
                                                            <!-- Lane header -->
                                                            <Border Padding="10,7" CornerRadius="4,4,0,0">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background"
                                                                                Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsUnassigned}" Value="True">
                                                                                <Setter Property="Background" Value="Transparent"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <Grid>
                                                                    <!-- Normal header display -->
                                                                    <Grid Visibility="{Binding IsRenaming, Converter={StaticResource InverseBoolToVisibility}}">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Grid.Column="0"
                                                                                   Text="{Binding PastureName}"
                                                                                   FontSize="13" FontWeight="SemiBold"
                                                                                   VerticalAlignment="Center"
                                                                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                                                                        <!-- Edit/Delete buttons — only for non-Unassigned lanes -->
                                                                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                                                    Visibility="{Binding IsUnassigned, Converter={StaticResource InverseBoolToVisibility}}">
                                                                            <Button Content="✏" FontSize="11" Padding="4,2"
                                                                                    ToolTip="Rename pasture"
                                                                                    Tag="{Binding}"
                                                                                    Click="RenamePastureBtn_Click"
                                                                                    Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}"/>
                                                                            <Button Content="✕" FontSize="11" Padding="4,2"
                                                                                    Foreground="Red"
                                                                                    ToolTip="Delete pasture"
                                                                                    Tag="{Binding}"
                                                                                    Click="DeletePastureBtn_Click"
                                                                                    Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}"/>
                                                                        </StackPanel>
                                                                    </Grid>

                                                                    <!-- Rename mode -->
                                                                    <Grid Visibility="{Binding IsRenaming, Converter={StaticResource BoolToVisibility}}">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBox Grid.Column="0"
                                                                                 Text="{Binding RenameText, UpdateSourceTrigger=PropertyChanged}"
                                                                                 FontSize="12" Padding="4,2"
                                                                                 Tag="{Binding}"
                                                                                 KeyDown="RenameTextBox_KeyDown"
                                                                                 LostFocus="RenameTextBox_LostFocus"
                                                                                 x:Name="RenameBox"/>
                                                                        <Button Grid.Column="1" Content="✓" FontSize="11" Padding="4,2"
                                                                                Tag="{Binding}"
                                                                                Click="CommitRenameBtn_Click"
                                                                                Style="{DynamicResource {x:Static ToolBar.ButtonStyleKey}}"/>
                                                                    </Grid>
                                                                </Grid>
                                                            </Border>

                                                            <!-- Animal cards -->
                                                            <ItemsControl ItemsSource="{Binding Animals}" Margin="6,6,6,6">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <WrapPanel Orientation="Horizontal"/>
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Width="86" Margin="3" CornerRadius="5"
                                                                                BorderThickness="1" Cursor="SizeAll"
                                                                                ToolTip="{Binding BarnName}"
                                                                                MouseMove="AnimalCard_MouseMove"
                                                                                Tag="{Binding}">
                                                                            <Border.Style>
                                                                                <Style TargetType="Border">
                                                                                    <Setter Property="Background"
                                                                                            Value="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
                                                                                    <Setter Property="BorderBrush"
                                                                                            Value="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
                                                                                </Style>
                                                                            </Border.Style>
                                                                            <StackPanel Margin="5,6,5,6" HorizontalAlignment="Center">
                                                                                <!-- Photo or placeholder -->
                                                                                <Grid Width="60" Height="60">
                                                                                    <Border Background="#E0E0E0" CornerRadius="3"/>
                                                                                    <TextBlock Text="🐄" FontSize="28"
                                                                                               HorizontalAlignment="Center"
                                                                                               VerticalAlignment="Center"/>
                                                                                    <Image Stretch="UniformToFill"
                                                                                           Source="{Binding PhotoPath, Converter={StaticResource PathToImage}}">
                                                                                        <Image.Clip>
                                                                                            <RectangleGeometry RadiusX="3" RadiusY="3" Rect="0,0,60,60"/>
                                                                                        </Image.Clip>
                                                                                        <Image.Style>
                                                                                            <Style TargetType="Image">
                                                                                                <Style.Triggers>
                                                                                                    <DataTrigger Binding="{Binding PhotoPath}" Value="{x:Null}">
                                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                                    </DataTrigger>
                                                                                                </Style.Triggers>
                                                                                            </Style>
                                                                                        </Image.Style>
                                                                                    </Image>
                                                                                </Grid>
                                                                                <TextBlock Text="{Binding BarnName}"
                                                                                           FontSize="11" TextWrapping="Wrap"
                                                                                           TextAlignment="Center"
                                                                                           MaxWidth="76" MaxHeight="32"
                                                                                           TextTrimming="CharacterEllipsis"
                                                                                           Margin="0,4,0,0"
                                                                                           Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                                                                                <Ellipse Width="8" Height="8" Margin="0,4,0,0"
                                                                                         HorizontalAlignment="Center"
                                                                                         Fill="{Binding Status, Converter={StaticResource StatusToBrush}}"/>
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>

                                                            <!-- Empty state -->
                                                            <TextBlock Margin="10,4,10,8"
                                                                       FontSize="11" FontStyle="Italic"
                                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                                       HorizontalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Animals.Count}" Value="0">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                                <Run Text="Drop animals here"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Add Pasture input -->
                                        <Border CornerRadius="6" Width="180" VerticalAlignment="Top"
                                                Margin="0,0,0,0"
                                                BorderThickness="1" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                                                Padding="10,8"
                                                Tag="{Binding}">
                                            <StackPanel>
                                                <TextBlock Text="+ Add Pasture" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumHighBrush}"
                                                           Margin="0,0,0,6"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Grid.Column="0"
                                                             Text="{Binding DataContext.NewPastureName, RelativeSource={RelativeSource AncestorType=Page}, UpdateSourceTrigger=PropertyChanged}"
                                                             ui:ControlHelper.PlaceholderText="Pasture name"
                                                             FontSize="12" Padding="5,3"
                                                             Tag="{Binding}"
                                                             KeyDown="AddPastureTextBox_KeyDown"/>
                                                    <Button Grid.Column="1" Content="✓" Padding="6,3" Margin="4,0,0,0"
                                                            FontSize="12"
                                                            Tag="{Binding}"
                                                            Click="AddPastureBtn_Click"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
