<Page x:Class="CattleManager.App.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="Dashboard">

    <!-- Converters and styles are defined globally in App.xaml -->

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24">

            <!-- Sample Data Banner -->
            <Border x:Name="SampleDataBanner"
                    Visibility="{Binding ShowSampleDataBanner, Converter={StaticResource BoolToVisibility}}"
                    Background="#FFF3E0" CornerRadius="8" Padding="16,12" Margin="0,0,0,16"
                    BorderBrush="#FFB74D" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="📋 Sample Data Loaded"
                                   FontWeight="SemiBold" FontSize="14" Foreground="#E65100"/>
                        <TextBlock Text="This app loaded with sample data to show you how it works. When you're ready to start fresh, click 'Clear Sample Data'."
                                   FontSize="12" Foreground="#BF360C" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="Clear Sample Data"
                            Command="{Binding ClearSampleDataCommand}"
                            Background="#E65100" Foreground="White"
                            Padding="16,8" Margin="12,0,0,0"
                            FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- Farm Header -->
            <Grid Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding FarmName}" FontSize="32" FontWeight="Bold"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                    <TextBlock Text="Herd Management Dashboard" FontSize="16"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Settings"
                        Command="{Binding OpenSettingsCommand}"
                        Padding="20,10" FontSize="14" VerticalAlignment="Center"/>
            </Grid>

            <!-- No herds message -->
            <TextBlock Text="No herds found. Create a herd to get started."
                       FontSize="15" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       Visibility="{Binding HasNoHerds, Converter={StaticResource BoolToVisibility}}"
                       Margin="0,0,0,24"/>

            <!-- Per-herd stat cards -->
            <ItemsControl ItemsSource="{Binding HerdCards}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,8">

                            <!-- Herd name + Add Animal -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding HerdName}"
                                           FontSize="20" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="+ Add Animal"
                                        Command="{Binding AddNewAnimalCommand}"
                                        Style="{StaticResource PrimaryButton}"/>
                            </Grid>

                            <!-- Stat cards -->
                            <WrapPanel Orientation="Horizontal" Margin="0,0,0,20">

                                <!-- Total Animals -->
                                <Button Style="{StaticResource StatCardButtonStyle}"
                                        Command="{Binding ViewHerdDetailsCommand}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding TotalAnimals}" FontSize="40" FontWeight="Bold"
                                                   Foreground="#00E676" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Total Animals" FontSize="13" HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Button>

                                <!-- Active Animals -->
                                <Button Style="{StaticResource StatCardButtonStyle}"
                                        Command="{Binding ViewActiveAnimalsCommand}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding ActiveAnimals}" FontSize="40" FontWeight="Bold"
                                                   Foreground="#69F0AE" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Active Animals" FontSize="13" HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Button>

                                <!-- Breeding Females -->
                                <Button Style="{StaticResource StatCardButtonStyle}"
                                        Command="{Binding ViewBreedingFemalesCommand}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding BreedingFemales}" FontSize="40" FontWeight="Bold"
                                                   Foreground="#FF4081" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Breeding Females" FontSize="13" HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Button>

                                <!-- Breeding Males -->
                                <Button Style="{StaticResource StatCardButtonStyle}"
                                        Command="{Binding ViewBreedingMalesCommand}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding BreedingMales}" FontSize="40" FontWeight="Bold"
                                                   Foreground="#2979FF" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Breeding Males" FontSize="13" HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Button>

                                <!-- Pregnant -->
                                <Button Style="{StaticResource StatCardButtonStyle}"
                                        Command="{Binding ViewPregnantCommand}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding PregnantAnimals}" FontSize="40" FontWeight="Bold"
                                                   Foreground="#D500F9" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Pregnant" FontSize="13" HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Button>

                                <!-- Due for Husbandry -->
                                <Button Style="{StaticResource StatCardButtonStyle}"
                                        Command="{Binding ViewDueForHusbandryCommand}">
                                    <Button.Background>
                                        <SolidColorBrush Color="{Binding DueForHusbandry, Converter={StaticResource CountToWarningColor}}"/>
                                    </Button.Background>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DueForHusbandry}" FontSize="40" FontWeight="Bold"
                                                   Foreground="#FF6D00" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Due for Husbandry" FontSize="13" HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Button>

                            </WrapPanel>

                            <Separator Background="{DynamicResource SystemControlForegroundBaseLowBrush}" Margin="0,0,0,20"/>

                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</Page>
