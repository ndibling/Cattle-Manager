<Page x:Class="CattleManager.App.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="Dashboard">

    <!-- Converters and NavButtonStyle are defined globally in App.xaml -->

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24">

            <!-- Sample Data Banner -->
            <Border x:Name="SampleDataBanner"
                    Visibility="{Binding ShowSampleDataBanner, Converter={StaticResource BoolToVisibility}}"
                    Background="#FFF3E0" CornerRadius="8" Padding="16,12" Margin="0,0,0,16"
                    BorderBrush="#FFB74D" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="📋 Sample Data Loaded"
                                   FontWeight="SemiBold" FontSize="14" Foreground="#E65100"/>
                        <TextBlock Text="This app loaded with sample data to show you how it works. When you're ready to start fresh, click 'Clear Sample Data'."
                                   FontSize="12" Foreground="#BF360C" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="Clear Sample Data"
                            Command="{Binding ClearSampleDataCommand}"
                            Background="#E65100" Foreground="White"
                            Padding="16,8" Margin="12,0,0,0"
                            FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- Farm Header -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding FarmName}" FontSize="32" FontWeight="Bold"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                    <TextBlock Text="Herd Management Dashboard" FontSize="16"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <!-- Herd Selector -->
                <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="Active Herd" FontSize="12"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding Herds2}"
                              SelectedItem="{Binding SelectedHerd}"
                              DisplayMemberPath="HerdName"
                              MinWidth="200" FontSize="14"/>
                </StackPanel>
            </Grid>

            <!-- Stat Cards -->
            <TextBlock Text="Herd Overview" Style="{StaticResource SectionHeaderStyle}"/>
            <WrapPanel Margin="0,0,0,24" Orientation="Horizontal">
                <!-- Total Animals -->
                <Button Style="{StaticResource StatCardButtonStyle}"
                        Command="{Binding ViewHerdDetailsCommand}">
                    <StackPanel>
                        <TextBlock Text="{Binding TotalAnimals}" FontSize="40" FontWeight="Bold"
                                   Foreground="#2E7D32" HorizontalAlignment="Center"/>
                        <TextBlock Text="Total Animals" FontSize="13" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
                <!-- Breeding Females -->
                <Button Style="{StaticResource StatCardButtonStyle}"
                        Command="{Binding ViewBreedingFemalesCommand}">
                    <StackPanel>
                        <TextBlock Text="{Binding BreedingFemales}" FontSize="40" FontWeight="Bold"
                                   Foreground="#AD1457" HorizontalAlignment="Center"/>
                        <TextBlock Text="Breeding Females" FontSize="13" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
                <!-- Breeding Males -->
                <Button Style="{StaticResource StatCardButtonStyle}"
                        Command="{Binding ViewBreedingMalesCommand}">
                    <StackPanel>
                        <TextBlock Text="{Binding BreedingMales}" FontSize="40" FontWeight="Bold"
                                   Foreground="#1565C0" HorizontalAlignment="Center"/>
                        <TextBlock Text="Breeding Males" FontSize="13" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
                <!-- Pregnant -->
                <Button Style="{StaticResource StatCardButtonStyle}"
                        Command="{Binding ViewPregnantCommand}">
                    <StackPanel>
                        <TextBlock Text="{Binding PregnantAnimals}" FontSize="40" FontWeight="Bold"
                                   Foreground="#6A1B9A" HorizontalAlignment="Center"/>
                        <TextBlock Text="Pregnant" FontSize="13" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
                <!-- Due for Husbandry -->
                <Button Style="{StaticResource StatCardButtonStyle}"
                        Command="{Binding ViewDueForHusbandryCommand}">
                    <Button.Background>
                        <SolidColorBrush Color="{Binding DueForHusbandry, Converter={StaticResource CountToWarningColor}}"/>
                    </Button.Background>
                    <StackPanel>
                        <TextBlock Text="{Binding DueForHusbandry}" FontSize="40" FontWeight="Bold"
                                   Foreground="#F57F17" HorizontalAlignment="Center"/>
                        <TextBlock Text="Due for Husbandry" FontSize="13" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
            </WrapPanel>

            <!-- Action Buttons -->
            <TextBlock Text="Quick Actions" Style="{StaticResource SectionHeaderStyle}"/>
            <WrapPanel Margin="0,0,0,0" Orientation="Horizontal">
                <Button Content="View Herd Details"
                        Command="{Binding ViewHerdDetailsCommand}"
                        Style="{StaticResource PrimaryButton}" Margin="0,0,12,12"/>
                <Button Content="Add New Animal"
                        Command="{Binding AddNewAnimalCommand}"
                        Padding="20,10" FontSize="14" Margin="0,0,12,12"/>
                <Button Content="Settings"
                        Command="{Binding OpenSettingsCommand}"
                        Padding="20,10" FontSize="14" Margin="0,0,12,12"/>
            </WrapPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
