<Page x:Class="CattleManager.App.Views.LoanFormPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="{Binding FormTitle}">

    <DockPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Padding="16,10"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding FormTitle}"
                           FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="{Binding ErrorText}" Foreground="#C62828"
                               VerticalAlignment="Center" Margin="0,0,16,0"
                               Visibility="{Binding ErrorText, Converter={StaticResource NullToVisibility}}"/>
                    <Button Content="Save" Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                    <Button Content="Cancel" Command="{Binding CancelCommand}" Padding="16,8"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Form body -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,16" MaxWidth="900">

                <!-- Loan Details -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Loan Details" Style="{StaticResource SectionHeaderStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Row 0: Lender (wide), Type -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,12,0">
                                <TextBlock Text="Lender Name *" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding LenderName, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="14" Padding="8,6"
                                         ui:ControlHelper.PlaceholderText="e.g. First Ag Bank"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Text="Loan Type *" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding LoanTypeOptions}"
                                          SelectedItem="{Binding SelectedLoanType}"
                                          DisplayMemberPath="Display" FontSize="14"/>
                            </StackPanel>

                            <!-- Row 1: Principal, Rate %, Start Date -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,8,12,0">
                                <TextBlock Text="Original Principal ($) *" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding OriginalPrincipalText, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="14" Padding="8,6"
                                         ui:ControlHelper.PlaceholderText="0.00"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,8,12,0">
                                <TextBlock Text="Interest Rate % *" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding InterestRateText, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="14" Padding="8,6"
                                         ui:ControlHelper.PlaceholderText="e.g. 6.5 for 6.5%"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,8,0,0">
                                <TextBlock Text="Start Date *" Style="{StaticResource FieldLabelStyle}"/>
                                <DatePicker SelectedDate="{Binding StartDate}" FontSize="14"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Payment Terms -->
                <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Text="Payment Terms" Style="{StaticResource SectionHeaderStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Payment Frequency *" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding FrequencyOptions}"
                                          SelectedItem="{Binding SelectedFrequency}"
                                          DisplayMemberPath="Display" FontSize="14"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <TextBlock Text="Payment Amount ($) *" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding PaymentAmountText, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="14" Padding="8,6"
                                         ui:ControlHelper.PlaceholderText="0.00"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Maturity Date" Style="{StaticResource FieldLabelStyle}"/>
                                <DatePicker SelectedDate="{Binding MaturityDate}" FontSize="14"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Margin="0,12,0,0">
                            <CheckBox Content="Loan is still active (not yet paid off)"
                                      IsChecked="{Binding IsActive}" FontSize="13"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Notes -->
                <Border Style="{StaticResource CardStyle}" Margin="0,8,0,16">
                    <StackPanel>
                        <TextBlock Text="Notes" Style="{StaticResource SectionHeaderStyle}"/>
                        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="14" Padding="8,6"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="72"
                                 ui:ControlHelper.PlaceholderText="Optional notes about this loan..."/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Page>
