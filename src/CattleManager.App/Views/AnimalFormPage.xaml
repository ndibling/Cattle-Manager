<Page x:Class="CattleManager.App.Views.AnimalFormPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      xmlns:conv="clr-namespace:CattleManager.App.Converters"
      xmlns:controls="clr-namespace:CattleManager.App.Controls"
      xmlns:core="clr-namespace:CattleManager.Core.Models;assembly=CattleManager.Core"
      Title="Animal Form">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <conv:PathToImageConverter x:Key="PathToImage"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisibility"/>
        <conv:AnimalStatusDisplayConverter x:Key="AnimalStatusDisplay"/>
    </Page.Resources>

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Padding="16,10"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding FormTitle}" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="{Binding ValidationError}" Foreground="Red"
                               VerticalAlignment="Center" Margin="0,0,16,0"
                               Visibility="{Binding ValidationError, Converter={StaticResource NullToVisibility}}"/>
                    <Button Content="Save" Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                    <Button Content="Cancel" Command="{Binding CancelCommand}" Padding="16,8"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,16">

                <!-- SECTION: Basic Information -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Basic Information" Style="{StaticResource SectionHeaderStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Barn Name *" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding BarnName, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="8,6"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,12,0">
                                <TextBlock Text="Registered Name" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding RegisteredName, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="8,6"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Text="Breed *" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding Breeds2}"
                                          SelectedItem="{Binding SelectedBreed}"
                                          DisplayMemberPath="BreedName" FontSize="14"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,8,12,0">
                                <TextBlock Text="Gender *" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding GenderOptions}" SelectedItem="{Binding Gender}" FontSize="14"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,8,12,0">
                                <TextBlock Text="Status *" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding Status}" FontSize="14">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource AnimalStatusDisplay}}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,8,0,0">
                                <TextBlock Text="Birth Date *" Style="{StaticResource FieldLabelStyle}"/>
                                <DatePicker SelectedDate="{Binding BirthDate}" FontSize="14"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,8,12,0">
                                <TextBlock Text="Tag Number" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding TagNumber, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="8,6"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,8,12,0">
                                <TextBlock Text="Chondro Status" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding ChondroOptions}" SelectedItem="{Binding Chondro}" FontSize="14"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- SECTION: Physical Characteristics -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Physical Characteristics" Style="{StaticResource SectionHeaderStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Weight" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding Weight, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="8,6"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <TextBlock Text="Unit" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding WeightUnitOptions}" SelectedItem="{Binding WeightUnit}" FontSize="14"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                <TextBlock Text="Height" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding Height, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="8,6"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="Unit" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding HeightUnitOptions}" SelectedItem="{Binding HeightUnit}" FontSize="14"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Text="Coloring / Markings" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding Coloring, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="8,6"/>
                        </StackPanel>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Registration Number" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding RegistrationNumber, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="8,6"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Registration Organization" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding RegistrationOrganization, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="8,6"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Expected Height at Maturity" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding ExpectedHeightAtMaturity, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="8,6"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <TextBlock Text="(same unit)" Style="{StaticResource FieldLabelStyle}" Foreground="Gray"/>
                                <TextBlock Text="{Binding HeightUnit}" FontSize="13" Margin="0,8,0,0" Foreground="Gray"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Horns" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding YesNoUnknownOptions}" SelectedItem="{Binding HornsSelection}" FontSize="14"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- SECTION: Location & Ownership -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Location &amp; Ownership" Style="{StaticResource SectionHeaderStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Breeder's Name" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding BreedersName, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="8,6"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Current Owner" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding CurrentOwner, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="8,6"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Pasture" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding PastureOptions}"
                                          SelectedItem="{Binding SelectedPastureOption}"
                                          FontSize="14"
                                          ui:ControlHelper.PlaceholderText="Select pasture…"/>
                                <!-- Inline new-pasture form -->
                                <Border Visibility="{Binding IsCreatingNewPasture, Converter={StaticResource BoolToVisibility}}"
                                        BorderThickness="1" CornerRadius="4" Padding="8,8" Margin="0,6,0,0"
                                        BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                        Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
                                    <StackPanel>
                                        <TextBlock Text="New Pasture" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <TextBox Text="{Binding NewPastureName, UpdateSourceTrigger=PropertyChanged}"
                                                 ui:ControlHelper.PlaceholderText="Pasture name (required)"
                                                 FontSize="13" Padding="6,4" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding NewPastureNotes, UpdateSourceTrigger=PropertyChanged}"
                                                 ui:ControlHelper.PlaceholderText="Notes (optional)"
                                                 FontSize="13" Padding="6,4" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Create" Command="{Binding SaveNewPastureCommand}"
                                                    Style="{StaticResource PrimaryButton}" Margin="0,0,6,0"/>
                                            <Button Content="Cancel" Command="{Binding CancelNewPastureCommand}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <TextBlock Text="Pasture State" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding StateOptions}" SelectedItem="{Binding PastureState}" FontSize="14"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Date Acquired" Style="{StaticResource FieldLabelStyle}"/>
                                <DatePicker SelectedDate="{Binding DateAcquired}" FontSize="14"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- SECTION: Acquisition -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Acquisition" Style="{StaticResource SectionHeaderStyle}"/>
                        <CheckBox Content="Born on this property" IsChecked="{Binding BornOnProperty}"
                                  FontSize="14" Margin="0,0,0,8"/>
                        <StackPanel Visibility="{Binding BornOnProperty, Converter={StaticResource InverseBoolToVisibility}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Seller Name" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding SellerName, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="8,6"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Seller Address" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding SellerAddress, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="8,6"/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Purchase Date" Style="{StaticResource FieldLabelStyle}"/>
                                    <DatePicker SelectedDate="{Binding PurchaseDate}" FontSize="14"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Purchase Price ($)" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding PurchasePrice, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="8,6"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- SECTION: Sale Information -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Sale Information" Style="{StaticResource SectionHeaderStyle}"/>
                        <CheckBox Content="For Sale" IsChecked="{Binding IsForSale}" FontSize="14" Margin="0,0,0,12"/>

                        <!-- Current Value — always visible -->
                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="Current Value ($)" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding CurrentValue, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="8,6" Width="200" HorizontalAlignment="Left"/>
                        </StackPanel>

                        <!-- Sale details — visible when For Sale or Sold -->
                        <StackPanel Visibility="{Binding ShowSaleSection, Converter={StaticResource BoolToVisibility}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Asking Price ($)" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding AskingPrice, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="8,6"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                    <TextBlock Text="Sale Price ($)" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding SalePrice, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="8,6"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                    <TextBlock Text="Date Sold" Style="{StaticResource FieldLabelStyle}"/>
                                    <DatePicker SelectedDate="{Binding SoldDate}" FontSize="14"/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Buyer Name" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding BuyerName, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="8,6"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Buyer Address" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding BuyerAddress, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="8,6"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- SECTION: Lineage -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Lineage" Style="{StaticResource SectionHeaderStyle}"/>
                        <!-- Sire -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
                                <TextBlock Text="Sire (Father)" Style="{StaticResource FieldLabelStyle}"/>
                                <CheckBox Content="Animal is in herd" IsChecked="{Binding SireInHerd}" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <ComboBox ItemsSource="{Binding AvailableMales}"
                                          SelectedItem="{Binding SelectedSire}"
                                          DisplayMemberPath="BarnName" FontSize="14"
                                          Visibility="{Binding SireInHerd, Converter={StaticResource BoolToVisibility}}"/>
                                <TextBox Text="{Binding ExternalSireName, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="14" Padding="8,6"
                                         ui:ControlHelper.PlaceholderText="Enter sire name (not in herd)"
                                         Visibility="{Binding SireInHerd, Converter={StaticResource InverseBoolToVisibility}}"/>
                            </StackPanel>
                        </Grid>
                        <!-- Dam -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
                                <TextBlock Text="Dam (Mother)" Style="{StaticResource FieldLabelStyle}"/>
                                <CheckBox Content="Animal is in herd" IsChecked="{Binding DamInHerd}" FontSize="13"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <ComboBox ItemsSource="{Binding AvailableFemales}"
                                          SelectedItem="{Binding SelectedDam}"
                                          DisplayMemberPath="BarnName" FontSize="14"
                                          Visibility="{Binding DamInHerd, Converter={StaticResource BoolToVisibility}}"/>
                                <TextBox Text="{Binding ExternalDamName, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="14" Padding="8,6"
                                         ui:ControlHelper.PlaceholderText="Enter dam name (not in herd)"
                                         Visibility="{Binding DamInHerd, Converter={StaticResource InverseBoolToVisibility}}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- SECTION: Health & Husbandry -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Health &amp; Husbandry" Style="{StaticResource SectionHeaderStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Last Worming Date" Style="{StaticResource FieldLabelStyle}"/>
                                <DatePicker SelectedDate="{Binding LastWormingDate}" FontSize="14"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Last Vaccination Date" Style="{StaticResource FieldLabelStyle}"/>
                                <DatePicker SelectedDate="{Binding LastVaccinationDate}" FontSize="14"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Last Health Check Date" Style="{StaticResource FieldLabelStyle}"/>
                                <DatePicker SelectedDate="{Binding LastHealthCheckDate}" FontSize="14"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Last Hoof Trimming Date" Style="{StaticResource FieldLabelStyle}"/>
                                <DatePicker SelectedDate="{Binding LastHoofTrimmingDate}" FontSize="14"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0"
                                        Visibility="{Binding IsFemale, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="Good Mother" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding YesNoUnknownOptions}" SelectedItem="{Binding IsGoodMotherSelection}" FontSize="14"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Text="Health Notes" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding HealthNotes, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="14" Padding="8,6" Height="80"
                                     TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- SECTION: Reproduction -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Reproduction" Style="{StaticResource SectionHeaderStyle}"/>
                        <CheckBox Content="Breeding Animal" IsChecked="{Binding IsBreeding}"
                                  IsEnabled="{Binding IsBreedingAllowed}"
                                  FontSize="14" Margin="0,0,0,8"/>
                        <TextBlock Text="Not available for Inactive or Deceased animals."
                                   FontSize="12" FontStyle="Italic"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   Margin="0,-4,0,8"
                                   Visibility="{Binding IsBreedingAllowed, Converter={StaticResource InverseBoolToVisibility}}"/>

                        <!-- Female only -->
                        <StackPanel>
                            <CheckBox Content="Currently Pregnant" IsChecked="{Binding IsPregnant}" FontSize="14" Margin="0,0,0,8"/>
                            <Grid Visibility="{Binding IsPregnant, Converter={StaticResource BoolToVisibility}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Sire of Current Calf" Style="{StaticResource FieldLabelStyle}"/>
                                    <ComboBox ItemsSource="{Binding AvailableMales}"
                                              SelectedItem="{Binding PregnancySire}"
                                              DisplayMemberPath="BarnName" FontSize="14"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                    <TextBlock Text="Breeding Date" Style="{StaticResource FieldLabelStyle}"/>
                                    <DatePicker SelectedDate="{Binding BreedingDate}" FontSize="14"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Expected Due Date (auto-calculated)" Style="{StaticResource FieldLabelStyle}"/>
                                    <DatePicker SelectedDate="{Binding ExpectedDueDate}" FontSize="14"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- Male only -->
                        <StackPanel Visibility="{Binding IsBreeding, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="Breeding Status" Style="{StaticResource FieldLabelStyle}" Margin="0,8,0,0"/>
                            <ComboBox ItemsSource="{Binding MaleBreedingStatusOptions}"
                                      SelectedItem="{Binding MaleBreedingStatus}"
                                      FontSize="14" HorizontalAlignment="Left" Width="200"/>
                        </StackPanel>

                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Text="Reproduction Notes" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding ReproductionNotes, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="14" Padding="8,6" Height="60"
                                     TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- SECTION: Photo -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Photo" Style="{StaticResource SectionHeaderStyle}"/>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="120" Height="160" CornerRadius="8"
                                    BorderThickness="1" BorderBrush="#CCCCCC" Margin="0,0,16,0">
                                <controls:PhotoPositionControl
                                    ImagePath="{Binding PhotoPath}"
                                    OffsetX="{Binding PhotoOffsetX, Mode=TwoWay}"
                                    OffsetY="{Binding PhotoOffsetY, Mode=TwoWay}"
                                    CornerRadius="7"
                                    IsInteractive="True"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <Button Content="📷 Choose Photo" Command="{Binding PickPhotoCommand}"
                                        Padding="16,8" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding PhotoPath}" FontSize="11" TextWrapping="Wrap"
                                           MaxWidth="300" Foreground="Gray"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Page>
