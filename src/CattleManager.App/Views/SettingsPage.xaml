<Page x:Class="CattleManager.App.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      xmlns:conv="clr-namespace:CattleManager.App.Converters"
      Title="Settings">

    <Page.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibility"/>
    </Page.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="16,10"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Settings" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="#2E7D32"
                               VerticalAlignment="Center" Margin="0,0,16,0"
                               Visibility="{Binding StatusMessage, Converter={StaticResource NullToVisibility}}"/>
                    <Button Content="Save Settings" Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,16">

                <!-- Farm Information -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Farm Information" Style="{StaticResource SectionHeaderStyle}"/>
                        <TextBlock Text="Farm Name *" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding FarmName, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="14" Padding="8,6" MaxWidth="400" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                        <TextBlock Text="Address" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding FarmAddress, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="14" Padding="8,6" MaxWidth="400" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                        <TextBlock Text="Contact Info" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding ContactInfo, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="14" Padding="8,6" MaxWidth="400" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Measurement Preferences -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Measurement Preferences" Style="{StaticResource SectionHeaderStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,32,0">
                                <TextBlock Text="Weight Unit" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding WeightUnitOptions}"
                                          SelectedItem="{Binding WeightUnit}" Width="180" FontSize="14"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Height Unit" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding HeightUnitOptions}"
                                          SelectedItem="{Binding HeightUnit}" Width="180" FontSize="14"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Application Preferences -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Application Preferences" Style="{StaticResource SectionHeaderStyle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,32,0">
                                <TextBlock Text="Color Theme" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding ThemeModeOptions}"
                                          SelectedItem="{Binding ThemeMode}" Width="180" FontSize="14"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Auto Backup" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding AutoBackupOptions}"
                                          SelectedItem="{Binding AutoBackup}" Width="180" FontSize="14"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Financial Settings -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Financial Settings" Style="{StaticResource SectionHeaderStyle}"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Fiscal Year Start Month" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding FiscalMonthOptions}"
                                          SelectedItem="{Binding FiscalYearStartMonth}"
                                          Width="180" FontSize="14"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Accounting Method" Style="{StaticResource FieldLabelStyle}"/>
                                <ComboBox ItemsSource="{Binding AccountingMethodOptions}"
                                          SelectedItem="{Binding AccountingMethod}"
                                          Width="180" FontSize="14"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="State of Operation" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding StateOfOperation, UpdateSourceTrigger=PropertyChanged}"
                                         Width="180" FontSize="14" Padding="8,6"
                                         ui:ControlHelper.PlaceholderText="e.g. Texas"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="State Sales Tax Rate %" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding StateSalesTaxRate, UpdateSourceTrigger=PropertyChanged}"
                                         Width="180" FontSize="14" Padding="8,6"
                                         ui:ControlHelper.PlaceholderText="e.g. 6.25"/>
                            </StackPanel>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="State Income Tax Rate %" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding StateIncomeTaxRate, UpdateSourceTrigger=PropertyChanged}"
                                         Width="180" FontSize="14" Padding="8,6"
                                         ui:ControlHelper.PlaceholderText="e.g. 5"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Est. Federal Income Tax Rate %" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Text="{Binding FederalIncomeTaxRate, UpdateSourceTrigger=PropertyChanged}"
                                         Width="180" FontSize="14" Padding="8,6"
                                         ui:ControlHelper.PlaceholderText="e.g. 22"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Data Backup -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Data Backup &amp; Restore" Style="{StaticResource SectionHeaderStyle}"/>
                        <TextBlock Text="Create a backup copy of your database or restore from a previous backup."
                                   FontSize="13" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                   Margin="0,0,0,12" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="💾 Backup Now" Command="{Binding BackupNowCommand}"
                                    Padding="16,8" Margin="0,0,12,0" Style="{StaticResource PrimaryButton}"/>
                            <Button Content="📂 Restore from Backup" Command="{Binding RestoreCommand}"
                                    Padding="16,8"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Data Management -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Data Management" Style="{StaticResource SectionHeaderStyle}"/>

                        <!-- CSV Import / Export -->
                        <TextBlock Text="Import / Export Animals (CSV)"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock Text="Import animals from a CSV file or export all animals to CSV. The CSV must include a header row. Download a template by exporting with no animals loaded."
                                   FontSize="13" TextWrapping="Wrap" Margin="0,0,0,12"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="📋 Download CSV Template"
                                    Command="{Binding DownloadCsvTemplateCommand}"
                                    Padding="16,8" Margin="0,0,12,0"/>
                            <Button Content="📥 Import Animals from CSV"
                                    Command="{Binding ImportAnimalsCsvCommand}"
                                    Padding="16,8" Margin="0,0,12,0" Style="{StaticResource PrimaryButton}"/>
                            <Button Content="📤 Export Animals to CSV"
                                    Command="{Binding ExportAnimalsCsvCommand}"
                                    Padding="16,8"/>
                        </StackPanel>
                        <TextBlock Text="{Binding DataStatusMessage}"
                                   Foreground="#2E7D32" FontSize="13"
                                   Visibility="{Binding DataStatusMessage, Converter={StaticResource NullToVisibility}}"
                                   Margin="0,0,0,16" TextWrapping="Wrap"/>

                        <Separator Margin="0,4,0,16"/>

                        <!-- Clear Database -->
                        <TextBlock Text="Clear Database"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock Text="Permanently delete all animals, herds, and financial records. Farm settings and preferences are preserved. This action cannot be undone."
                                   FontSize="13" TextWrapping="Wrap" Margin="0,0,0,12"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        <Button Content="🗑 Clear All Data"
                                Command="{Binding ClearDatabaseCommand}"
                                Padding="16,8"
                                Background="#C62828" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Page>
