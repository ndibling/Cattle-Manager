<Page x:Class="CattleManager.App.Views.BudgetPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      xmlns:vm="clr-namespace:CattleManager.App.ViewModels"
      xmlns:local="clr-namespace:CattleManager.App.Views"
      Title="Budget">

    <Page.Resources>
        <!-- Green for income, red for expense -->
        <Style x:Key="TypeBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Background" Value="#1565C0"/>
        </Style>
    </Page.Resources>

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Padding="16,12"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Budget Planning" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Margin="16,0,0,0" FontSize="13" VerticalAlignment="Center"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                        Loading…
                    </TextBlock>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Clear Budget"
                            Command="{Binding ClearBudgetCommand}"
                            Padding="14,8" Margin="0,0,8,0" FontSize="14"/>
                    <Button Content="Save Budget"
                            Command="{Binding SaveBudgetCommand}"
                            Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Financial sub-navigation -->
        <Border DockPanel.Dock="Top" Padding="12,6"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Dashboard" Command="{Binding NavigateToDashboardCommand}"
                        Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand"
                        Padding="10,4" VerticalAlignment="Center"/>
                <TextBlock Text="·" FontSize="14" Margin="2,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"/>
                <Button Content="Transactions" Command="{Binding NavigateToTransactionsCommand}"
                        Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand"
                        Padding="10,4" VerticalAlignment="Center"/>
                <TextBlock Text="·" FontSize="14" Margin="2,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"/>
                <Button Content="Assets" Command="{Binding NavigateToAssetsCommand}"
                        Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand"
                        Padding="10,4" VerticalAlignment="Center"/>
                <TextBlock Text="·" FontSize="14" Margin="2,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"/>
                <Button Content="Loans" Command="{Binding NavigateToLoansCommand}"
                        Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand"
                        Padding="10,4" VerticalAlignment="Center"/>
                <TextBlock Text="·" FontSize="14" Margin="2,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"/>
                <Button Content="Reports" Command="{Binding NavigateToReportsCommand}"
                        Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand"
                        Padding="10,4" VerticalAlignment="Center"/>
                <TextBlock Text="·" FontSize="14" Margin="2,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Budget" FontSize="13" FontWeight="SemiBold" Padding="10,4"
                           Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Fiscal year + add-category bar -->
        <Border DockPanel.Dock="Top" Padding="16,10"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Fiscal year selector -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Fiscal Year:" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox ItemsSource="{Binding FiscalYearOptions}"
                              SelectedItem="{Binding FiscalYear}"
                              Width="120" FontSize="14"/>
                </StackPanel>
                <!-- Add category -->
                <Button Grid.Column="2"
                        Content="+ Add Budget Line"
                        Command="{Binding AddCategoryCommand}"
                        Padding="14,8" FontSize="13"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Scrollable body: chart + category cards -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

            <!-- Bar chart -->
            <local:BudgetChartControl
                ChartData="{Binding MonthlyChartData}"
                Visibility="{Binding HasNoCategories, Converter={StaticResource InverseBoolToVisibility}}"/>

            <!-- Empty state -->
            <TextBlock Text="No categories in this budget yet. Click '+ Add Category' above to get started."
                       FontSize="14" Margin="24,24" TextWrapping="Wrap"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       Visibility="{Binding HasNoCategories, Converter={StaticResource BoolToVisibility}}"/>

            <!-- Category cards -->
            <ItemsControl ItemsSource="{Binding Categories}" Margin="16,8,16,16">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:BudgetCategoryViewModel}">
                        <Expander Margin="0,0,0,8">
                            <Expander.Header>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Type badge -->
                                    <Border Grid.Column="0" CornerRadius="4" Padding="6,2" Margin="0,0,12,0"
                                            VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#1565C0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TypeDisplay}" Value="Expense">
                                                        <Setter Property="Background" Value="#C62828"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding TypeDisplay}" Foreground="White"
                                                   FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                    <!-- Category name -->
                                    <TextBlock Grid.Column="1" Text="{Binding CategoryDisplay}"
                                               FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <!-- Annual Budget -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="Annual Budget" FontSize="10"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                        <TextBlock Text="{Binding AnnualBudgetDisplay}" FontSize="13" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <!-- Actual YTD -->
                                    <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                        <TextBlock Text="Actual YTD" FontSize="10"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                        <TextBlock Text="{Binding AnnualActualDisplay}" FontSize="13"/>
                                    </StackPanel>
                                    <!-- Variance -->
                                    <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                        <TextBlock Text="Variance" FontSize="10"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                        <TextBlock Text="{Binding AnnualVarianceDisplay}" FontSize="13">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsOverBudget}" Value="True">
                                                            <Setter Property="Foreground" Value="#EF5350"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                    <!-- Remove button -->
                                    <Button Grid.Column="6" Content="✕ Remove"
                                            Command="{Binding DataContext.RemoveCategoryCommand,
                                                RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Padding="10,4" FontSize="12"
                                            VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </Grid>
                            </Expander.Header>

                            <!-- Monthly breakdown DataGrid -->
                            <DataGrid ItemsSource="{Binding Months}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserReorderColumns="False"
                                      CanUserSortColumns="False"
                                      SelectionMode="Single"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                      HeadersVisibility="Column"
                                      FontSize="13" RowHeight="34"
                                      Margin="0,4,0,4">

                                <DataGrid.Resources>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background"      Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"/>
                                        <Setter Property="Foreground"      Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                                        <Setter Property="Padding"         Value="12,6"/>
                                        <Setter Property="FontWeight"      Value="SemiBold"/>
                                        <Setter Property="FontSize"        Value="12"/>
                                        <Setter Property="BorderBrush"     Value="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
                                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                    </Style>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Padding" Value="12,0"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                </DataGrid.Resources>

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Month" Binding="{Binding MonthName}"
                                                        Width="120" IsReadOnly="True"/>

                                    <!-- Budget Amount (editable) -->
                                    <DataGridTemplateColumn Header="Budget Amount" Width="150">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding BudgetAmount, StringFormat=C}"
                                                           HorizontalAlignment="Right" Padding="12,0" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding BudgetAmount, UpdateSourceTrigger=PropertyChanged}"
                                                         HorizontalAlignment="Stretch" Padding="8,4"
                                                         VerticalAlignment="Center"
                                                         ui:ControlHelper.PlaceholderText="0.00"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>

                                    <!-- Actual -->
                                    <DataGridTextColumn Header="Actual" Binding="{Binding ActualDisplay}"
                                                        Width="130" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="Padding" Value="12,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>

                                    <!-- Variance -->
                                    <DataGridTemplateColumn Header="Variance" Width="130" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding VarianceDisplay}"
                                                           HorizontalAlignment="Right" Padding="12,0" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsOverBudget}" Value="True">
                                                                    <Setter Property="Foreground" Value="#EF5350"/>
                                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Page>
