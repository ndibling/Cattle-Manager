<Window x:Class="CattleManager.App.Views.PhotoLightboxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Photo Viewer"
        Width="960" Height="700"
        MinWidth="480" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        KeyDown="Window_KeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Photo display — black background keeps focus on the image -->
        <Border Grid.Row="0" Background="Black">
            <Image x:Name="MainImage" Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
        </Border>

        <!-- Navigation bar -->
        <Border Grid.Row="1" Padding="16,10"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="PrevButton" Grid.Column="0"
                        Content="← Prev" Click="Prev_Click"
                        Padding="16,8" FontSize="13"/>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center"
                            VerticalAlignment="Center" Margin="12,0">
                    <TextBlock x:Name="CountLabel" HorizontalAlignment="Center"
                               FontSize="13" FontWeight="SemiBold"/>
                    <TextBlock x:Name="DateLabel" HorizontalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBlock x:Name="CaptionLabel" HorizontalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               TextWrapping="Wrap" MaxWidth="500" TextAlignment="Center"/>
                </StackPanel>

                <Button x:Name="NextButton" Grid.Column="2"
                        Content="Next →" Click="Next_Click"
                        Padding="16,8" FontSize="13"/>
            </Grid>
        </Border>
    </Grid>
</Window>
