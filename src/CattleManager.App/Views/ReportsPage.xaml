<Page x:Class="CattleManager.App.Views.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      Title="Financial Reports">

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Padding="16,12"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Financial Reports" FontSize="22" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Margin="0,0,12,0" VerticalAlignment="Center" FontSize="13"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                        Running report…
                    </TextBlock>
                    <Button Content="Export PDF"
                            Command="{Binding ExportPdfCommand}"
                            Background="#1565C0" Foreground="White"
                            Padding="14,8" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Financial sub-navigation -->
        <Border DockPanel.Dock="Top" Padding="12,6"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Dashboard" Command="{Binding NavigateToDashboardCommand}"
                        Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand"
                        Padding="10,4" VerticalAlignment="Center"/>
                <TextBlock Text="·" FontSize="14" Margin="2,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"/>
                <Button Content="Transactions" Command="{Binding NavigateToTransactionsCommand}"
                        Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand"
                        Padding="10,4" VerticalAlignment="Center"/>
                <TextBlock Text="·" FontSize="14" Margin="2,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"/>
                <Button Content="Assets" Command="{Binding NavigateToAssetsCommand}"
                        Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand"
                        Padding="10,4" VerticalAlignment="Center"/>
                <TextBlock Text="·" FontSize="14" Margin="2,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"/>
                <Button Content="Loans" Command="{Binding NavigateToLoansCommand}"
                        Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand"
                        Padding="10,4" VerticalAlignment="Center"/>
                <TextBlock Text="·" FontSize="14" Margin="2,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Reports" FontSize="13" FontWeight="SemiBold" Padding="10,4"
                           Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="·" FontSize="14" Margin="2,0"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"/>
                <Button Content="Budget" Command="{Binding NavigateToBudgetCommand}"
                        Background="Transparent" BorderThickness="0" FontSize="13" Cursor="Hand"
                        Padding="10,4" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Tab control -->
        <TabControl SelectedIndex="{Binding SelectedTabIndex}" FontSize="13">

            <!-- ══════════════════════════════════════════════
                 Tab 0 — Profit & Loss
                 ══════════════════════════════════════════════ -->
            <TabItem Header="Profit &amp; Loss">
                <DockPanel>
                    <!-- Period selector -->
                    <Border DockPanel.Dock="Top" Padding="16,10"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                        <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                                <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <DatePicker SelectedDate="{Binding PnlFrom}" MinWidth="130" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="To:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <DatePicker SelectedDate="{Binding PnlTo}" MinWidth="130" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Content="Run Report" Command="{Binding RunReportCommand}"
                                    Style="{StaticResource PrimaryButton}" VerticalAlignment="Center"/>
                        </WrapPanel>
                    </Border>

                    <!-- Placeholder when no report -->
                    <TextBlock DockPanel.Dock="Top" Text="Select a date range and click Run Report."
                               FontSize="14" Margin="24,24,0,0"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               Visibility="{Binding HasPnlResult, Converter={StaticResource InverseBoolToVisibility}}"/>

                    <!-- Report content -->
                    <ScrollViewer DockPanel.Dock="Top"
                                  Visibility="{Binding HasPnlResult, Converter={StaticResource BoolToVisibility}}"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="24,16,24,24" MaxWidth="700" HorizontalAlignment="Left">

                            <!-- Income section -->
                            <TextBlock Text="INCOME" FontSize="15" FontWeight="Bold" Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding PnlResult.IncomeByCategory}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Category}" Padding="16,0,0,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Amount, StringFormat=C}"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Gross Revenue" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="{Binding PnlResult.GrossRevenue, StringFormat=C}"
                                           FontWeight="SemiBold" HorizontalAlignment="Right"/>
                            </Grid>

                            <Separator Margin="0,10"/>

                            <!-- Expenses section -->
                            <TextBlock Text="EXPENSES" FontSize="15" FontWeight="Bold" Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding PnlResult.ExpensesByCategory}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Category}" Padding="16,0,0,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Amount, StringFormat=C}"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Total Cash Expenses" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="{Binding PnlResult.TotalExpenses, StringFormat=C}"
                                           FontWeight="SemiBold" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,2,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="  Interest Expense" FontStyle="Italic"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding PnlResult.InterestExpense, StringFormat=C}"
                                           FontStyle="Italic" HorizontalAlignment="Right"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            </Grid>
                            <Grid Margin="0,2,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="  Depreciation" FontStyle="Italic"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding PnlResult.DepreciationTotal, StringFormat=C}"
                                           FontStyle="Italic" HorizontalAlignment="Right"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            </Grid>

                            <Separator Margin="0,10"/>

                            <!-- Net Farm Income -->
                            <Border Background="#E8F5E9" CornerRadius="6" Padding="12,8" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="NET FARM INCOME" FontWeight="Bold" FontSize="15"
                                               Foreground="#2E7D32"/>
                                    <TextBlock Grid.Column="1" Text="{Binding PnlResult.NetFarmIncome, StringFormat=C}"
                                               FontWeight="Bold" FontSize="15" HorizontalAlignment="Right"
                                               Foreground="#2E7D32"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- ══════════════════════════════════════════════
                 Tab 1 — Balance Sheet
                 ══════════════════════════════════════════════ -->
            <TabItem Header="Balance Sheet">
                <DockPanel>
                    <!-- Date selector -->
                    <Border DockPanel.Dock="Top" Padding="16,10"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                        <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="As of:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <DatePicker SelectedDate="{Binding BsAsOf}" MinWidth="130" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Content="Run Report" Command="{Binding RunReportCommand}"
                                    Style="{StaticResource PrimaryButton}" VerticalAlignment="Center"/>
                        </WrapPanel>
                    </Border>

                    <TextBlock DockPanel.Dock="Top" Text="Select a date and click Run Report."
                               FontSize="14" Margin="24,24,0,0"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               Visibility="{Binding HasBsResult, Converter={StaticResource InverseBoolToVisibility}}"/>

                    <ScrollViewer DockPanel.Dock="Top"
                                  Visibility="{Binding HasBsResult, Converter={StaticResource BoolToVisibility}}"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="24,16,24,24" MaxWidth="700" HorizontalAlignment="Left">

                            <!-- ASSETS -->
                            <TextBlock Text="ASSETS" FontSize="15" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBlock Text="Current Assets" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="  Cash (approximate)" Padding="16,0,0,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding BsResult.CashApproximate, StringFormat=C}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="  Livestock Inventory" Padding="16,0,0,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding BsResult.LivestockInventoryValue, StringFormat=C}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,4,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Total Current Assets" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="{Binding BsResult.TotalCurrentAssets, StringFormat=C}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                            </Grid>

                            <TextBlock Text="Fixed Assets" FontWeight="SemiBold" Margin="0,10,0,4"/>
                            <ItemsControl ItemsSource="{Binding BsResult.FixedAssets}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Name}" Padding="16,0,0,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding BookValue, StringFormat=C}" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="  Gross Fixed Assets" FontStyle="Italic" Padding="16,0,0,0"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding BsResult.TotalFixedAssetsGross, StringFormat=C}" FontStyle="Italic"
                                           HorizontalAlignment="Right" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            </Grid>
                            <Grid Margin="0,4,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Total Fixed Assets (net)" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="{Binding BsResult.TotalFixedAssetsNet, StringFormat=C}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                            </Grid>

                            <Border Background="#E8F5E9" CornerRadius="6" Padding="12,8" Margin="0,8">
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="TOTAL ASSETS" FontWeight="Bold" FontSize="14" Foreground="#2E7D32"/>
                                    <TextBlock Grid.Column="1" Text="{Binding BsResult.TotalAssets, StringFormat=C}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Right" Foreground="#2E7D32"/>
                                </Grid>
                            </Border>

                            <Separator Margin="0,6"/>

                            <!-- LIABILITIES -->
                            <TextBlock Text="LIABILITIES" FontSize="15" FontWeight="Bold" Margin="0,0,0,6"/>
                            <TextBlock Text="Current Liabilities" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="  Operating Line of Credit" Padding="16,0,0,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding BsResult.OperatingLineBalance, StringFormat=C}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,4,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Total Current Liabilities" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="{Binding BsResult.TotalCurrentLiabilities, StringFormat=C}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                            </Grid>

                            <TextBlock Text="Long-Term Liabilities" FontWeight="SemiBold" Margin="0,10,0,4"/>
                            <ItemsControl ItemsSource="{Binding BsResult.LongTermLoans}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0,0,0">
                                                <TextBlock Text="{Binding LenderName}"/>
                                                <TextBlock Text=" (" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                                <TextBlock Text="{Binding LoanType}" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                                <TextBlock Text=")" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding Balance, StringFormat=C}" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid Margin="0,4,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Total Long-Term Liabilities" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="{Binding BsResult.TotalLongTermLiabilities, StringFormat=C}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                            </Grid>

                            <Border Background="#FFEBEE" CornerRadius="6" Padding="12,8" Margin="0,8">
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="TOTAL LIABILITIES" FontWeight="Bold" FontSize="14" Foreground="#C62828"/>
                                    <TextBlock Grid.Column="1" Text="{Binding BsResult.TotalLiabilities, StringFormat=C}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Right" Foreground="#C62828"/>
                                </Grid>
                            </Border>

                            <Separator Margin="0,6"/>

                            <Border Background="#E3F2FD" CornerRadius="6" Padding="12,8" Margin="0,0,0,16">
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="OWNER'S EQUITY" FontWeight="Bold" FontSize="15" Foreground="#1565C0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding BsResult.OwnersEquity, StringFormat=C}" FontWeight="Bold" FontSize="15" HorizontalAlignment="Right" Foreground="#1565C0"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- ══════════════════════════════════════════════
                 Tab 2 — Cash Flow
                 ══════════════════════════════════════════════ -->
            <TabItem Header="Cash Flow">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="16,10"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                        <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,8,0" VerticalAlignment="Center">
                                <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <DatePicker SelectedDate="{Binding CfFrom}" MinWidth="130" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="To:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <DatePicker SelectedDate="{Binding CfTo}" MinWidth="130" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Content="Run Report" Command="{Binding RunReportCommand}"
                                    Style="{StaticResource PrimaryButton}" VerticalAlignment="Center"/>
                        </WrapPanel>
                    </Border>

                    <TextBlock DockPanel.Dock="Top" Text="Select a date range and click Run Report."
                               FontSize="14" Margin="24,24,0,0"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               Visibility="{Binding HasCfResult, Converter={StaticResource InverseBoolToVisibility}}"/>

                    <ScrollViewer DockPanel.Dock="Top"
                                  Visibility="{Binding HasCfResult, Converter={StaticResource BoolToVisibility}}"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="24,16,24,24" MaxWidth="700" HorizontalAlignment="Left">

                            <TextBlock Text="OPERATING ACTIVITIES" FontSize="15" FontWeight="Bold" Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding CfResult.OperatingItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Category}" Padding="16,0,0,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Amount, StringFormat=C}" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid Margin="0,4,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Net from Operations" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="{Binding CfResult.OperatingActivities, StringFormat=C}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                            </Grid>

                            <Separator Margin="0,10"/>

                            <TextBlock Text="INVESTING ACTIVITIES" FontSize="15" FontWeight="Bold" Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding CfResult.InvestingItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Category}" Padding="16,0,0,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Amount, StringFormat=C}" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid Margin="0,4,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Net from Investing" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="{Binding CfResult.InvestingActivities, StringFormat=C}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                            </Grid>

                            <Separator Margin="0,10"/>

                            <TextBlock Text="FINANCING ACTIVITIES" FontSize="15" FontWeight="Bold" Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding CfResult.FinancingItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Category}" Padding="16,0,0,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Amount, StringFormat=C}" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid Margin="0,4,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Net from Financing" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="{Binding CfResult.FinancingActivities, StringFormat=C}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                            </Grid>

                            <Border Background="#E8F5E9" CornerRadius="6" Padding="12,8" Margin="0,12,0,16">
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="NET CASH CHANGE" FontWeight="Bold" FontSize="15" Foreground="#2E7D32"/>
                                    <TextBlock Grid.Column="1" Text="{Binding CfResult.NetCashChange, StringFormat=C}" FontWeight="Bold" FontSize="15" HorizontalAlignment="Right" Foreground="#2E7D32"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- ══════════════════════════════════════════════
                 Tab 3 — Tax Summary
                 ══════════════════════════════════════════════ -->
            <TabItem Header="Tax Summary">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="16,10"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                        <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Center">
                                <TextBlock Text="Fiscal Year:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <ComboBox ItemsSource="{Binding TaxYearOptions}"
                                          SelectedItem="{Binding TaxYear}"
                                          MinWidth="80" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Content="Run Report" Command="{Binding RunReportCommand}"
                                    Style="{StaticResource PrimaryButton}" VerticalAlignment="Center"/>
                        </WrapPanel>
                    </Border>

                    <TextBlock DockPanel.Dock="Top" Text="Select a fiscal year and click Run Report."
                               FontSize="14" Margin="24,24,0,0"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               Visibility="{Binding HasTaxResult, Converter={StaticResource InverseBoolToVisibility}}"/>

                    <ScrollViewer DockPanel.Dock="Top"
                                  Visibility="{Binding HasTaxResult, Converter={StaticResource BoolToVisibility}}"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="24,16,24,24" MaxWidth="700" HorizontalAlignment="Left">

                            <TextBlock Text="INCOME SUMMARY" FontSize="15" FontWeight="Bold" Margin="0,0,0,6"/>
                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="  Gross Livestock Sales" Padding="16,0,0,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding TaxResult.TotalGrossSales, StringFormat=C}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="  Other Farm Income" Padding="16,0,0,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding TaxResult.TotalOtherIncome, StringFormat=C}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="  Total Expenses" Padding="16,0,0,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding TaxResult.TotalExpenses, StringFormat=C}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,4,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Net Farm Income" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="{Binding TaxResult.NetFarmIncome, StringFormat=C}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                            </Grid>

                            <Separator Margin="0,10"/>

                            <TextBlock Text="ESTIMATED TAX LIABILITY" FontSize="15" FontWeight="Bold" Margin="0,0,0,6"/>
                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="  Self-Employment Tax (15.3%)" Padding="16,0,0,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding TaxResult.SelfEmploymentTax, StringFormat=C}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="  Est. Federal Income Tax" Padding="16,0,0,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding TaxResult.EstimatedFederalTax, StringFormat=C}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="  Est. State Income Tax" Padding="16,0,0,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding TaxResult.EstimatedStateTax, StringFormat=C}" HorizontalAlignment="Right"/>
                            </Grid>

                            <!-- Schedule F items (shown only if present) -->
                            <TextBlock Text="SCHEDULE F ITEMS" FontSize="15" FontWeight="Bold" Margin="0,14,0,6"
                                       Visibility="{Binding HasScheduleF, Converter={StaticResource BoolToVisibility}}"/>
                            <ItemsControl ItemsSource="{Binding TaxResult.ScheduleFItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding LineDescription}" Padding="16,0,0,0" FontSize="12"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Amount, StringFormat=C}" HorizontalAlignment="Right" FontSize="12"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Capital gains (shown only if present) -->
                            <TextBlock Text="CAPITAL GAIN / LOSS EVENTS" FontSize="15" FontWeight="Bold" Margin="0,14,0,6"
                                       Visibility="{Binding HasCapitalGains, Converter={StaticResource BoolToVisibility}}"/>
                            <ItemsControl ItemsSource="{Binding TaxResult.CapitalGainEvents}" Margin="0,0,0,16">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,6" Padding="12,8"
                                                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                                CornerRadius="4">
                                            <StackPanel>
                                                <TextBlock Text="{Binding AssetDescription}" FontWeight="SemiBold"/>
                                                <Grid Margin="0,4,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0">
                                                        <Run Text="Cost: "/><Run Text="{Binding CostBasis, StringFormat=C}"/>
                                                    </TextBlock>
                                                    <TextBlock Grid.Column="1">
                                                        <Run Text="Sale: "/><Run Text="{Binding SalePrice, StringFormat=C}"/>
                                                    </TextBlock>
                                                    <TextBlock Grid.Column="2" FontWeight="SemiBold">
                                                        <Run Text="Gain/Loss: "/><Run Text="{Binding GainOrLoss, StringFormat=C}"/>
                                                    </TextBlock>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- ══════════════════════════════════════════════
                 Tab 4 — Bill of Sale
                 ══════════════════════════════════════════════ -->
            <TabItem Header="Bill of Sale">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="16,12"
                            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                        <StackPanel>
                            <TextBlock Text="Select a livestock sale transaction to generate a Bill of Sale PDF."
                                       Margin="0,0,0,10" FontSize="13"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ComboBox ItemsSource="{Binding SaleTransactions}"
                                          SelectedItem="{Binding SelectedSale}"
                                          MinWidth="320" Margin="0,0,12,0" VerticalAlignment="Center"
                                          DisplayMemberPath="Description"/>
                                <Button Content="Generate Bill of Sale PDF"
                                        Command="{Binding GenerateBillOfSaleCommand}"
                                        Background="#2E7D32" Foreground="White"
                                        Padding="14,8" FontWeight="SemiBold" BorderThickness="0"
                                        Cursor="Hand" VerticalAlignment="Center"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- No sale transactions placeholder -->
                    <TextBlock DockPanel.Dock="Top"
                               Text="No livestock sale transactions found. Add income transactions with the Livestock Sales category to generate Bills of Sale."
                               FontSize="14" Margin="24,24" TextWrapping="Wrap"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               Visibility="{Binding HasSaleTransactions, Converter={StaticResource InverseBoolToVisibility}}"/>

                    <!-- Selected sale details -->
                    <ScrollViewer DockPanel.Dock="Top"
                                  Visibility="{Binding SelectedSale, Converter={StaticResource NullToVisibility}}"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="24,16,24,24" MaxWidth="600" HorizontalAlignment="Left">
                            <TextBlock Text="TRANSACTION PREVIEW" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Date:" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedSale.Date, StringFormat='MMMM d, yyyy'}"/>
                            </Grid>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Description:" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedSale.Description}" TextWrapping="Wrap"/>
                            </Grid>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Buyer:" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedSale.PayeePayer}"/>
                            </Grid>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Amount:" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedSale.Amount, StringFormat=C}"
                                           FontWeight="SemiBold" FontSize="15" Foreground="#2E7D32"/>
                            </Grid>
                            <!-- Linked animal details -->
                            <StackPanel Margin="0,10,0,0"
                                        Visibility="{Binding SaleLinkedAnimal, Converter={StaticResource NullToVisibility}}">
                                <TextBlock Text="LINKED ANIMAL" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Name:" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SaleLinkedAnimal.BarnName}"/>
                                </Grid>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Breed:" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SaleLinkedAnimal.BreedName}"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
</Page>
