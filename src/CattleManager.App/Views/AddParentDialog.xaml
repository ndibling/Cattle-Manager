<Window x:Class="CattleManager.App.Views.AddParentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        SizeToContent="Height" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <StackPanel Margin="20">

        <!-- Title -->
        <TextBlock x:Name="TitleText" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <!-- In-herd toggle -->
        <RadioButton x:Name="InHerdRadio" Content="Animal in this herd" IsChecked="True"
                     FontSize="14" Margin="0,0,0,8"
                     Checked="InHerdRadio_Checked"/>
        <ComboBox x:Name="AnimalCombo"
                  DisplayMemberPath="BarnName"
                  FontSize="14" Margin="0,0,0,16"
                  HorizontalAlignment="Stretch"/>

        <!-- External toggle -->
        <RadioButton x:Name="ExternalRadio" Content="External animal (not in herd)"
                     FontSize="14" Margin="0,0,0,8"
                     Checked="ExternalRadio_Checked"/>
        <TextBox x:Name="ExternalNameBox"
                 ui:ControlHelper.PlaceholderText="Enter animal name"
                 FontSize="14" Padding="8,6" Margin="0,0,0,16"
                 IsEnabled="False"
                 KeyDown="ExternalNameBox_KeyDown"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Padding="16,8" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Assign" Padding="16,8" IsDefault="True" Click="Assign_Click"
                    Style="{StaticResource PrimaryButton}"/>
        </StackPanel>

    </StackPanel>
</Window>
