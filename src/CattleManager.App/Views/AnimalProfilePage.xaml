<Page x:Class="CattleManager.App.Views.AnimalProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.modernwpf.com/2019"
      xmlns:conv="clr-namespace:CattleManager.App.Converters"
      Title="Animal Profile">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <conv:StatusToBrushConverter x:Key="StatusToBrush"/>
        <conv:AnimalStatusDisplayConverter x:Key="AnimalStatusDisplay"/>
        <conv:GenderToBorderBrushConverter x:Key="GenderToBorder"/>
        <conv:GenderToSymbolConverter x:Key="GenderToSymbol"/>
        <conv:PathToImageConverter x:Key="PathToImage"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisibility"/>
    </Page.Resources>

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Padding="16,10"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="← Back" Command="{Binding GoBackCommand}" Padding="12,6"/>
                <TextBlock Grid.Column="1" Text="{Binding Animal.BarnName}" FontSize="20" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="16,0"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="Edit Profile" Command="{Binding EditProfileCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                            Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisibility}}"/>
                    <Button Content="✏️ Edit Mode" Command="{Binding EnterEditModeCommand}"
                            Padding="12,6" Margin="0,0,8,0"
                            Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisibility}}"/>
                    <Button Content="💾 Save Changes" Command="{Binding SaveChangesCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                            Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}"/>
                    <Button Content="Cancel" Command="{Binding CancelEditCommand}"
                            Padding="12,6" Margin="0,0,8,0"
                            Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}"/>
                    <Button Content="View Lineage" Command="{Binding ViewLineageCommand}" Padding="12,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="24,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Photo & Basic Info -->
                <StackPanel Grid.Column="0" Margin="0,0,24,0">
                    <!-- Photo -->
                    <Border CornerRadius="8" ClipToBounds="True"
                            BorderThickness="3"
                            BorderBrush="{Binding Animal.Gender, Converter={StaticResource GenderToBorder}}"
                            Margin="0,0,0,16">
                        <Grid>
                            <Image Source="{Binding Animal.PhotoPath, Converter={StaticResource PathToImage}}"
                                   Width="258" Height="340" Stretch="UniformToFill"/>
                            <Button Content="📷 Change Photo"
                                    Command="{Binding ChangePhotoCommand}"
                                    Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}"
                                    VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                                    Background="#CC000000" Foreground="White"
                                    BorderThickness="0" Padding="8,8"/>
                        </Grid>
                    </Border>

                    <!-- Gender + Status badge -->
                    <WrapPanel Margin="0,0,0,16">
                        <Border Background="{Binding Animal.Gender, Converter={StaticResource GenderToBorder}}"
                                CornerRadius="12" Padding="10,4" Margin="0,0,8,0">
                            <TextBlock Text="{Binding Animal.Gender, Converter={StaticResource GenderToSymbol}}"
                                       Foreground="White" FontWeight="Bold"/>
                        </Border>
                        <Border Background="{Binding Animal.Status, Converter={StaticResource StatusToBrush}}"
                                CornerRadius="12" Padding="10,4">
                            <TextBlock Text="{Binding Animal.Status, Converter={StaticResource AnimalStatusDisplay}}" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                        </Border>
                    </WrapPanel>

                    <!-- Upcoming tasks -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Upcoming Tasks" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding UpcomingTasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="12"
                                                   Foreground="#F57F17" TextWrapping="Wrap" Margin="0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="No tasks due" FontSize="12" Foreground="Gray"
                                       Visibility="{Binding HasNoUpcomingTasks, Converter={StaticResource BoolToVisibility}}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- RIGHT: Details panels -->
                <StackPanel Grid.Column="1">

                    <!-- Basic Information -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Basic Information" Style="{StaticResource SectionHeaderStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Barn Name" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding Animal.BarnName}" Style="{StaticResource FieldValueStyle}" FontWeight="SemiBold" FontSize="16"
                                               Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisibility}}"/>
                                    <TextBox Text="{Binding EditBarnName, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="6,4" Margin="0,0,0,4"
                                             Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}"/>
                                    <TextBlock Text="Registered Name" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding Animal.RegisteredName}" Style="{StaticResource FieldValueStyle}"
                                               Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisibility}}"/>
                                    <TextBox Text="{Binding EditRegisteredName, UpdateSourceTrigger=PropertyChanged}" FontSize="13" Padding="6,4" Margin="0,0,0,4"
                                             Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}"/>
                                    <TextBlock Text="Breed" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding Animal.BreedName}" Style="{StaticResource FieldValueStyle}"/>
                                    <TextBlock Text="Tag Number" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding Animal.TagNumber}" Style="{StaticResource FieldValueStyle}"
                                               Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisibility}}"/>
                                    <TextBox Text="{Binding EditTagNumber, UpdateSourceTrigger=PropertyChanged}" FontSize="13" Padding="6,4" Margin="0,0,0,4"
                                             Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Birth Date" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding Animal.BirthDate, StringFormat='MMMM d, yyyy'}" Style="{StaticResource FieldValueStyle}"/>
                                    <TextBlock Text="Age" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding Animal.AgeDisplay}" Style="{StaticResource FieldValueStyle}"/>
                                    <TextBlock Text="Gender" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding Animal.Gender}" Style="{StaticResource FieldValueStyle}"/>
                                    <TextBlock Text="Chondro" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding Animal.Chondro}" Style="{StaticResource FieldValueStyle}"
                                               Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisibility}}"/>
                                    <ComboBox ItemsSource="{Binding ChondroOptions}" SelectedItem="{Binding EditChondro}" FontSize="13" Margin="0,0,0,4"
                                              Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Location -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Location" Style="{StaticResource SectionHeaderStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Pasture Address" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding Animal.PastureLocation}" Style="{StaticResource FieldValueStyle}"
                                               Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisibility}}"/>
                                    <TextBox Text="{Binding EditPastureLocation, UpdateSourceTrigger=PropertyChanged}" FontSize="13" Padding="6,4" Margin="0,0,0,4"
                                             Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Pasture State" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding Animal.PastureState}" Style="{StaticResource FieldValueStyle}"
                                               Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisibility}}"/>
                                    <ComboBox ItemsSource="{Binding StateOptions}" SelectedItem="{Binding EditPastureState}" FontSize="13" Margin="0,0,0,4"
                                              Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Purchase Details -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Purchase Details" Style="{StaticResource SectionHeaderStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Purchase Date" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding Animal.PurchaseDate, StringFormat=MM/dd/yyyy}" Style="{StaticResource FieldValueStyle}"/>
                                    <TextBlock Text="Purchase Price" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding Animal.PurchasePrice, StringFormat=C}" Style="{StaticResource FieldValueStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Seller" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding Animal.SellerName}" Style="{StaticResource FieldValueStyle}"/>
                                    <TextBlock Text="Seller Address" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding Animal.SellerAddress}" Style="{StaticResource FieldValueStyle}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Sale &amp; Valuation -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Sale &amp; Valuation" Style="{StaticResource SectionHeaderStyle}"/>

                            <!-- For Sale toggle: read-only badge in view mode, checkbox in edit mode -->
                            <CheckBox Content="For Sale" IsChecked="{Binding EditIsForSale}"
                                      IsEnabled="{Binding IsEditMode}"
                                      FontSize="14" Margin="0,0,0,8"/>

                            <!-- Current Value — always visible -->
                            <TextBlock Text="Current Value" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="{Binding Animal.CurrentValue, StringFormat=C}" Style="{StaticResource FieldValueStyle}"/>

                            <!-- Sale details — visible when For Sale or animal is Sold -->
                            <StackPanel Visibility="{Binding ShowSaleDetails, Converter={StaticResource BoolToVisibility}}">
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Asking Price" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBlock Text="{Binding Animal.AskingPrice, StringFormat=C}" Style="{StaticResource FieldValueStyle}"
                                                   Foreground="#1565C0" FontWeight="SemiBold"/>
                                        <TextBlock Text="Sale Price" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBlock Text="{Binding Animal.SalePrice, StringFormat=C}" Style="{StaticResource FieldValueStyle}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Date Sold" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBlock Text="{Binding Animal.SoldDate, StringFormat=MM/dd/yyyy}" Style="{StaticResource FieldValueStyle}"/>
                                        <TextBlock Text="Buyer" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBlock Text="{Binding Animal.BuyerName}" Style="{StaticResource FieldValueStyle}"/>
                                        <TextBlock Text="Buyer Address" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBlock Text="{Binding Animal.BuyerAddress}" Style="{StaticResource FieldValueStyle}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Physical Characteristics -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Physical Characteristics" Style="{StaticResource SectionHeaderStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Weight" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding Animal.WeightDisplay}" Style="{StaticResource FieldValueStyle}"/>
                                    <TextBlock Text="Coloring/Markings" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding Animal.Coloring}" Style="{StaticResource FieldValueStyle}" TextWrapping="Wrap"
                                               Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisibility}}"/>
                                    <TextBox Text="{Binding EditColoring, UpdateSourceTrigger=PropertyChanged}" FontSize="13" Padding="6,4" Margin="0,0,0,4"
                                             Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}"/>
                                    <TextBlock Text="Horns" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding Animal.HornsDisplay}" Style="{StaticResource FieldValueStyle}"
                                               Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisibility}}"/>
                                    <ComboBox ItemsSource="{Binding YesNoUnknownOptions}" SelectedItem="{Binding EditHornsSelection}" FontSize="13" Margin="0,0,0,4"
                                              Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Height" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding Animal.HeightDisplay}" Style="{StaticResource FieldValueStyle}"/>
                                    <TextBlock Text="Exp. Height at Maturity" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding Animal.ExpectedHeightAtMaturityDisplay}" Style="{StaticResource FieldValueStyle}"
                                               Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisibility}}"/>
                                    <TextBox Text="{Binding EditExpectedHeightAtMaturity, UpdateSourceTrigger=PropertyChanged}" FontSize="13" Padding="6,4" Margin="0,0,0,4"
                                             Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}"/>
                                    <TextBlock Text="Registration #" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding Animal.RegistrationNumber}" Style="{StaticResource FieldValueStyle}"/>
                                    <TextBlock Text="Reg. Organization" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding Animal.RegistrationOrganization}" Style="{StaticResource FieldValueStyle}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Health & Husbandry -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Health &amp; Husbandry" Style="{StaticResource SectionHeaderStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Last Worming" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding Animal.LastWormingDate, StringFormat=MM/dd/yyyy}" Style="{StaticResource FieldValueStyle}"
                                               Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisibility}}"/>
                                    <DatePicker SelectedDate="{Binding EditLastWorming}" FontSize="13" Margin="0,0,0,4"
                                                Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}"/>
                                    <TextBlock Text="Last Vaccination" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding Animal.LastVaccinationDate, StringFormat=MM/dd/yyyy}" Style="{StaticResource FieldValueStyle}"
                                               Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisibility}}"/>
                                    <DatePicker SelectedDate="{Binding EditLastVaccination}" FontSize="13" Margin="0,0,0,4"
                                                Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}"/>
                                    <StackPanel Visibility="{Binding IsFemale, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="Good Mother" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBlock Text="{Binding Animal.IsGoodMotherDisplay}" Style="{StaticResource FieldValueStyle}"
                                                   Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisibility}}"/>
                                        <ComboBox ItemsSource="{Binding YesNoUnknownOptions}" SelectedItem="{Binding EditIsGoodMotherSelection}" FontSize="13" Margin="0,0,0,4"
                                                  Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Last Health Check" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding Animal.LastHealthCheckDate, StringFormat=MM/dd/yyyy}" Style="{StaticResource FieldValueStyle}"
                                               Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisibility}}"/>
                                    <DatePicker SelectedDate="{Binding EditLastHealthCheck}" FontSize="13" Margin="0,0,0,4"
                                                Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}"/>
                                    <TextBlock Text="Last Hoof Trimming" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding Animal.LastHoofTrimmingDate, StringFormat=MM/dd/yyyy}" Style="{StaticResource FieldValueStyle}"
                                               Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisibility}}"/>
                                    <DatePicker SelectedDate="{Binding EditLastHoofTrimming}" FontSize="13" Margin="0,0,0,4"
                                                Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Health Notes" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock Text="{Binding Animal.HealthNotes}" Style="{StaticResource FieldValueStyle}" TextWrapping="Wrap"
                                       Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisibility}}"/>
                            <TextBox Text="{Binding EditHealthNotes, UpdateSourceTrigger=PropertyChanged}" FontSize="13" Padding="6,4" Height="60"
                                     TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,4"
                                     Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibility}}"/>

                            <!-- Health History -->
                            <TextBlock Text="Health History" FontWeight="SemiBold" Margin="0,8,0,4"/>
                            <DataGrid ItemsSource="{Binding HealthHistory}" AutoGenerateColumns="False"
                                      CanUserAddRows="False" IsReadOnly="True" MaxHeight="180"
                                      GridLinesVisibility="Horizontal" FontSize="12">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Date" Binding="{Binding RecordDate, StringFormat=MM/dd/yyyy}" Width="90"/>
                                    <DataGridTextColumn Header="Type" Binding="{Binding RecordType}" Width="110"/>
                                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                    <DataGridTextColumn Header="Vet" Binding="{Binding VeterinarianName}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- Reproduction -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Reproduction" Style="{StaticResource SectionHeaderStyle}"/>

                            <!-- Breeding Animal indicator -->
                            <TextBlock Text="Breeding Animal" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource FieldValueStyle}">
                                        <Setter Property="Text" Value="No"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Animal.IsBreeding}" Value="True">
                                                <Setter Property="Text" Value="Yes"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Female breeding details -->
                            <StackPanel Visibility="{Binding Animal.IsPregnant, Converter={StaticResource BoolToVisibility}}"
                                        Margin="0,8,0,0">
                                <TextBlock Text="Currently Pregnant" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBlock Text="Yes" Style="{StaticResource FieldValueStyle}" Foreground="#1565C0" FontWeight="SemiBold"/>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Sire of Current Calf" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource FieldValueStyle}">
                                                    <Setter Property="Text" Value="{Binding Animal.PregnancySireBarnName}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Animal.PregnancySireBarnName}" Value="{x:Null}">
                                                            <Setter Property="Text" Value="—"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Breeding Date" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBlock Text="{Binding Animal.BreedingDate, StringFormat=MM/dd/yyyy}" Style="{StaticResource FieldValueStyle}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Expected Due Date" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBlock Text="{Binding Animal.ExpectedDueDate, StringFormat=MM/dd/yyyy}" Style="{StaticResource FieldValueStyle}"
                                                   Foreground="#2E7D32" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <!-- Male breeding status -->
                            <StackPanel Visibility="{Binding Animal.MaleBreedingStatus, Converter={StaticResource NullToVisibility}}"
                                        Margin="0,8,0,0">
                                <TextBlock Text="Breeding Status" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBlock Text="{Binding Animal.MaleBreedingStatus}" Style="{StaticResource FieldValueStyle}"/>
                            </StackPanel>

                            <!-- Reproduction Notes -->
                            <StackPanel Visibility="{Binding Animal.ReproductionNotes, Converter={StaticResource NullToVisibility}}"
                                        Margin="0,8,0,0">
                                <TextBlock Text="Reproduction Notes" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBlock Text="{Binding Animal.ReproductionNotes}" Style="{StaticResource FieldValueStyle}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Lineage -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Lineage" Style="{StaticResource SectionHeaderStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Sire (Father)" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding Animal.SireBarnName}" Style="{StaticResource FieldValueStyle}"/>
                                    <TextBlock Text="{Binding Animal.ExternalSireName}" Style="{StaticResource FieldValueStyle}" Foreground="Gray"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Dam (Mother)" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBlock Text="{Binding Animal.DamBarnName}" Style="{StaticResource FieldValueStyle}"/>
                                    <TextBlock Text="{Binding Animal.ExternalDamName}" Style="{StaticResource FieldValueStyle}" Foreground="Gray"/>
                                </StackPanel>
                            </Grid>
                            <Button Content="View Full Pedigree →" Command="{Binding ViewLineageCommand}"
                                    Padding="16,8" Margin="0,8,0,0" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <!-- Offspring -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Offspring in Herd" Style="{StaticResource SectionHeaderStyle}"/>
                            <DataGrid ItemsSource="{Binding Offspring}" AutoGenerateColumns="False"
                                      CanUserAddRows="False" IsReadOnly="True" MaxHeight="180"
                                      GridLinesVisibility="Horizontal" FontSize="12"
                                      MouseDoubleClick="Offspring_MouseDoubleClick">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Barn Name" Binding="{Binding BarnName}" Width="130" FontWeight="SemiBold"/>
                                    <DataGridTextColumn Header="Gender" Binding="{Binding Gender}" Width="70"/>
                                    <DataGridTextColumn Header="Age" Binding="{Binding AgeDisplay}" Width="80"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- Photos -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Photos" Style="{StaticResource SectionHeaderStyle}" Margin="0"/>
                                <Button Content="+ Add Photo" Command="{Binding AddPhotoCommand}"
                                        HorizontalAlignment="Right" Padding="12,4" FontSize="12"/>
                            </Grid>
                            <WrapPanel>
                                <ItemsControl ItemsSource="{Binding AnimalPhotos}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="4">
                                                <Border Width="120" Height="120" CornerRadius="6" ClipToBounds="True"
                                                        BorderThickness="1" BorderBrush="#CCCCCC">
                                                    <Image Source="{Binding FilePath, Converter={StaticResource PathToImage}}"
                                                           Stretch="UniformToFill"/>
                                                </Border>
                                                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top"
                                                        Width="20" Height="20" Padding="0" FontSize="10"
                                                        Background="#CC000000" Foreground="White" BorderThickness="0"
                                                        Command="{Binding DataContext.DeletePhotoCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"/>
                                                <TextBlock Text="{Binding Caption}" VerticalAlignment="Bottom"
                                                           HorizontalAlignment="Center" FontSize="10"
                                                           Foreground="Gray" TextWrapping="Wrap" MaxWidth="116"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Attachments -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Attachments" Style="{StaticResource SectionHeaderStyle}" Margin="0"/>
                                <Button Content="+ Add File" Command="{Binding AddAttachmentCommand}"
                                        HorizontalAlignment="Right" Padding="12,4" FontSize="12"/>
                            </Grid>
                            <DataGrid ItemsSource="{Binding AnimalAttachments}" AutoGenerateColumns="False"
                                      CanUserAddRows="False" IsReadOnly="True" MaxHeight="160"
                                      GridLinesVisibility="Horizontal" FontSize="12">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*" FontWeight="SemiBold"/>
                                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                    <DataGridTemplateColumn Width="60">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Remove" FontSize="10" Padding="4,2"
                                                        Command="{Binding DataContext.DeleteAttachmentCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- Bull Exposure Records -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Bull Exposure Records" Style="{StaticResource SectionHeaderStyle}" Margin="0"/>
                                <Button Content="+ Log Exposure" Command="{Binding ShowAddExposureCommand}"
                                        HorizontalAlignment="Right" Padding="12,4" FontSize="12"
                                        Visibility="{Binding IsAddingExposure, Converter={StaticResource InverseBoolToVisibility}}"/>
                            </Grid>
                            <DataGrid ItemsSource="{Binding BullExposureRecords}" AutoGenerateColumns="False"
                                      CanUserAddRows="False" IsReadOnly="True" MaxHeight="180"
                                      GridLinesVisibility="Horizontal" FontSize="12">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Bull" Binding="{Binding BullDisplay}" Width="120" FontWeight="SemiBold"/>
                                    <DataGridTextColumn Header="Start Date" Binding="{Binding StartDate, StringFormat=MM/dd/yyyy}" Width="90"/>
                                    <DataGridTextColumn Header="End Date" Binding="{Binding EndDate, StringFormat=MM/dd/yyyy}" Width="90"/>
                                    <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*"/>
                                    <DataGridTemplateColumn Width="60">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Remove" FontSize="10" Padding="4,2"
                                                        Command="{Binding DataContext.DeleteExposureCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Inline Add Exposure Form -->
                            <Border Margin="0,12,0,0" Padding="12"
                                    Background="{DynamicResource SystemControlBackgroundChromeLowBrush}"
                                    CornerRadius="6"
                                    Visibility="{Binding IsAddingExposure, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel>
                                    <TextBlock Text="Log New Exposure" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <CheckBox Content="Bull is in herd" IsChecked="{Binding NewExposureSireInHerd}"
                                                  FontSize="13" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        <ComboBox ItemsSource="{Binding AvailableSires}"
                                                  SelectedItem="{Binding NewExposureSire}"
                                                  DisplayMemberPath="BarnName" FontSize="13" Width="200"
                                                  Visibility="{Binding NewExposureSireInHerd, Converter={StaticResource BoolToVisibility}}"/>
                                        <TextBox Text="{Binding NewExposureExternalSireName, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="13" Padding="6,4" Width="200"
                                                 ui:ControlHelper.PlaceholderText="Bull name (not in herd)"
                                                 Visibility="{Binding NewExposureSireInHerd, Converter={StaticResource InverseBoolToVisibility}}"/>
                                    </StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="Start Date" Style="{StaticResource FieldLabelStyle}"/>
                                            <DatePicker SelectedDate="{Binding NewExposureStartDate}" FontSize="13"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="End Date" Style="{StaticResource FieldLabelStyle}"/>
                                            <DatePicker SelectedDate="{Binding NewExposureEndDate}" FontSize="13"/>
                                        </StackPanel>
                                    </Grid>
                                    <StackPanel Margin="0,0,0,8">
                                        <TextBlock Text="Notes" Style="{StaticResource FieldLabelStyle}"/>
                                        <TextBox Text="{Binding NewExposureNotes, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="13" Padding="6,4" Height="54"
                                                 TextWrapping="Wrap" AcceptsReturn="True"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Save" Command="{Binding SaveExposureCommand}"
                                                Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" Padding="16,6"/>
                                        <Button Content="Cancel" Command="{Binding CancelAddExposureCommand}" Padding="16,6"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Page>
