<?xml version="1.0" encoding="utf-8" ?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <Format>cobertura</Format>
          <Exclude>
            <!-- WPF layer: requires live dispatcher, cannot run in headless CI -->
            [CattleManager.App]*,
            <!-- EF Core migration classes: never executed by InMemory tests -->
            [CattleManager.Data]CattleManager.Data.Migrations.*,
            <!-- ExportService: PDF/CSV generation requires real filesystem renderer -->
            [CattleManager.Core]CattleManager.Core.Services.ExportService
          </Exclude>
          <ExcludeByAttribute>ExcludeFromCodeCoverageAttribute</ExcludeByAttribute>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
